---
import '../styles/theme.css';

const { title, description, lang = 'en', toolName, category, categorySlug, isTool = false, faqList = [] } = Astro.props;

// Determine paths for canonicals and alternates
const canonicalPath = Astro.url.pathname;
const cleanPath = canonicalPath.replace(/^\/(hi|es|fr|de|pt|it|nl|ru|tr|pl|uk|ar|fa|ur|bn|pa|ta|te|mr|gu|zh|ja|ko|th|vi|id|ms|fil)/, '');
const normalizedCleanPath = cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;

// Generate canonical URL
const canonicalURL = `https://convertocean.com${normalizedCleanPath.replace(/\/+$/, '/')}`;

// List of all supported locales
const locales = [
  { code: 'en', name: 'English' },
  { code: 'hi', name: 'हिन्दी' },
  { code: 'es', name: 'Español' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'pt', name: 'Português' },
  { code: 'it', name: 'Italiano' },
  { code: 'nl', name: 'Nederlands' },
  { code: 'ru', name: 'Русский' },
  { code: 'tr', name: 'Türkçe' },
  { code: 'pl', name: 'Polski' },
  { code: 'uk', name: 'Українська' },
  { code: 'ar', name: 'العربية' },
  { code: 'fa', name: 'فارسی' },
  { code: 'ur', name: 'اردو' },
  { code: 'bn', name: 'বাংলা' },
  { code: 'pa', name: 'ਪੰਜਾਬੀ' },
  { code: 'ta', name: 'தமிழ்' },
  { code: 'te', name: 'తెలుగు' },
  { code: 'mr', name: 'मराठी' },
  { code: 'gu', name: 'ગુજરાતી' },
  { code: 'zh', name: '中文' },
  { code: 'ja', name: '日本語' },
  { code: 'ko', name: '한국어' },
  { code: 'th', name: 'ไทย' },
  { code: 'vi', name: 'Tiếng Việt' },
  { code: 'id', name: 'Bahasa Indonesia' },
  { code: 'ms', name: 'Bahasa Melayu' },
  { code: 'fil', name: 'Filipino' }
];

const alternates = locales.map(locale => {
  let href = '';
  const path = normalizedCleanPath.replace(/\/+$/, '/');
  if (locale.code === 'en') {
    href = `https://convertocean.com${path}`;
  } else {
    href = `https://convertocean.com/${locale.code}${path}`;
  }
  return { lang: locale.code, href };
});

// JSON-LD Schema Models
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ConvertOcean",
  "url": "https://convertocean.com",
  "logo": "https://convertocean.com/favicon.svg"
};

const breadcrumbList = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": lang === 'en' ? "https://convertocean.com/" : `https://convertocean.com/${lang}/`
  }
];

if (category && categorySlug) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": 2,
    "name": category,
    "item": lang === 'en' ? `https://convertocean.com/${categorySlug}/` : `https://convertocean.com/${lang}/${categorySlug}/`
  });
}

if (isTool && toolName) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": category ? 3 : 2,
    "name": toolName,
    "item": canonicalURL
  });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbList
};

const softwareSchema = isTool ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName || title,
  "operatingSystem": "All",
  "applicationCategory": "UtilityApplication",
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD"
  }
} : null;

const faqSchema = faqList && faqList.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqList.map((faq: { q: string; a: string }) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

// Helper to prefix links with language prefix if not default 'en'
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- Canonical & Alternates -->
  <link rel="canonical" href={canonicalURL} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))}
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <!-- Favicon and App Icons -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="COcean" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://convertocean.com/apple-touch-icon.png" />
  <meta property="og:site_name" content="ConvertOcean" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://convertocean.com/apple-touch-icon.png" />

  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  )}

  <!-- Pre-render theme code to prevent flashing -->
  <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>

  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  {softwareSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
  )}
</head>
<body>
  <div class="hero-glow"></div>

  <!-- Header -->
  <header class="nav-bar">
    <a href={relLink('/')} class="nav-brand">
      <img src="/fevicon.png" alt="ConvertOcean Logo" class="brand-logo-img" style="width: 42px; height: 42px; object-fit: contain; flex-shrink: 0; transition: transform 0.2s ease;" />
      <span class="brand-text">Convert<span style="color: #00dfd8; font-weight: 700;">Ocean</span></span>
    </a>
    
    <nav class="nav-links">
      <a href={relLink('/')} class="nav-link">⚡ Home</a>
      <a href={relLink('/file-converter/')} class="nav-link">📄 File Converter</a>
      <a href={relLink('/pdf-tools/')} class="nav-link">📑 PDF Tools</a>
      <a href={relLink('/image-tools/')} class="nav-link">🖼️ Image Tools</a>
      <a href={relLink('/excel-converter/')} class="nav-link">📊 Excel Converter</a>
      <a href={relLink('/image-to-text/')} class="nav-link">🔍 Image to Text</a>
      <a href={relLink('/business-tools/')} class="nav-link">💼 Business Tools</a>
      <a href={relLink('/privacy-first/')} class="nav-link">🔒 Privacy First</a>
    </nav>

    <div class="nav-right-group">
      <span class="nav-badge"><span class="pulse-dot"></span> Offline Ready</span>
      
      <!-- Language Selector -->
      <div style="position: relative; display: inline-block;">
        <select id="langSelector" class="select-input" style="height: 32px; font-size: 12.5px; padding: 0 var(--spacing-sm); border-radius: var(--rounded-sm); min-width: 90px;" aria-label="Select Language">
          {locales.map(locale => (
            <option value={locale.code} selected={locale.code === lang}>{locale.name}</option>
          ))}
        </select>
      </div>

      <button id="themeToggle" class="theme-toggle-btn" aria-label="Toggle dark mode">
        <svg id="themeToggleIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        </svg>
      </button>
      <button id="mobileMenuBtn" class="mobile-menu-btn" aria-label="Open navigation menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Dropdown Menu -->
  <div id="mobileNavMenu" class="mobile-nav-menu">
    <a href={relLink('/')} class="mobile-nav-link">⚡ Home</a>
    <a href={relLink('/file-converter/')} class="mobile-nav-link">📄 File Converter</a>
    <a href={relLink('/pdf-tools/')} class="mobile-nav-link">📑 PDF Tools</a>
    <a href={relLink('/image-tools/')} class="mobile-nav-link">🖼️ Image Tools</a>
    <a href={relLink('/excel-converter/')} class="mobile-nav-link">📊 Excel Converter</a>
    <a href={relLink('/image-to-text/')} class="mobile-nav-link">🔍 Image to Text</a>
    <a href={relLink('/business-tools/')} class="mobile-nav-link">💼 Business Tools</a>
    <a href={relLink('/privacy-first/')} class="mobile-nav-link">🔒 Privacy First</a>
    <div style="padding: 6px 12px; display: flex; flex-direction: column; gap: 4px;">
      <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--colors-mute); margin-top: 4px;">Language</span>
      <select id="mobileLangSelector" class="select-input" style="height: 36px; font-size: 13.5px;" aria-label="Select Language Mobile">
        {locales.map(locale => (
          <option value={locale.code} selected={locale.code === lang}>{locale.name}</option>
        ))}
      </select>
    </div>
  </div>

  <slot />

  <!-- Footer -->
  <footer>
    <div class="footer-content">
      <div class="footer-top">
        <div class="footer-brand">
          <a href={relLink('/')} class="nav-brand" style="margin-bottom: 8px;">
            <img src="/fevicon.png" alt="ConvertOcean Logo" class="brand-logo-img" style="width: 42px; height: 42px; object-fit: contain; flex-shrink: 0; transition: transform 0.2s ease;" />
            <span class="brand-text">Convert<span style="color: #00dfd8; font-weight: 700;">Ocean</span></span>
          </a>
          <p class="footer-desc">Privacy-first browser-based file utilities. Convert, merge, split and extract file data 100% locally in your browser sandbox.</p>
        </div>
        <div class="footer-column">
          <span class="footer-title">File Converter</span>
          <div class="footer-links">
            <a href={relLink('/excel-to-pdf/')} class="footer-link">Excel to PDF</a>
            <a href={relLink('/csv-to-json/')} class="footer-link">CSV to JSON</a>
            <a href={relLink('/json-to-csv/')} class="footer-link">JSON to CSV</a>
            <a href={relLink('/xlsx-to-csv/')} class="footer-link">XLSX to CSV</a>
            <a href={relLink('/csv-to-xlsx/')} class="footer-link">CSV to XLSX</a>
            <a href={relLink('/json-to-xlsx/')} class="footer-link">JSON to XLSX</a>
            <a href={relLink('/xml-to-json/')} class="footer-link">XML to JSON</a>
          </div>
        </div>
        <div class="footer-column">
          <span class="footer-title">PDF & Document</span>
          <div class="footer-links">
            <a href={relLink('/merge-pdf/')} class="footer-link">Merge PDF</a>
            <a href={relLink('/split-pdf/')} class="footer-link">Split PDF</a>
            <a href={relLink('/txt-to-pdf/')} class="footer-link">TXT to PDF</a>
            <a href={relLink('/pdf-to-txt/')} class="footer-link">PDF to TXT</a>
            <a href={relLink('/document-tools/')} class="footer-link">Document Tools</a>
            <a href={relLink('/excel-converter/')} class="footer-link">Excel Converter</a>
          </div>
        </div>
        <div class="footer-column">
          <span class="footer-title">Image & OCR</span>
          <div class="footer-links">
            <a href={relLink('/png-to-jpg/')} class="footer-link">PNG to JPG</a>
            <a href={relLink('/jpg-to-png/')} class="footer-link">JPG to PNG</a>
            <a href={relLink('/png-to-webp/')} class="footer-link">PNG to WebP</a>
            <a href={relLink('/webp-to-png/')} class="footer-link">WebP to PNG</a>
            <a href={relLink('/image-to-text/')} class="footer-link">Image to Text OCR</a>
            <a href={relLink('/image-tools/')} class="footer-link">Image Tools</a>
          </div>
        </div>
        <div class="footer-column">
          <span class="footer-title">Legal & Company</span>
          <div class="footer-links">
            <a href={relLink('/privacy-first/')} class="footer-link">Privacy Policy</a>
            <a href={relLink('/privacy-first/')} class="footer-link">Terms of Service</a>
            <a href={relLink('/privacy-first/')} class="footer-link">Contact</a>
            <a href="/sitemap-index.xml" class="footer-link">Sitemap</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="privacy-disclaimer">
          <strong>🔒 100% Device-Level Security Guarantee:</strong> Disconnect your internet connection completely and try any tool. It works flawlessly because your files never touch an external server. Everything resides in local sandbox memory and is automatically removed when you close the tab.
        </p>
        <p class="copyright">&copy; 2026 ConvertOcean. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    import '../scripts/theme.js';
  </script>
</body>
</html>
