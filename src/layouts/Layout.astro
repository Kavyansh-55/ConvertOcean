---
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, lang = 'en', toolName, category, categorySlug, isTool = false, faqList = [], article = null } = Astro.props;

// Determine paths for canonicals and alternates
const canonicalPath = Astro.url.pathname;
const cleanPath = canonicalPath.replace(/^\/(hi|es|fr|de|pt|it|nl|ru|tr|pl|uk|ar|fa|ur|bn|pa|ta|te|mr|gu|zh|ja|ko|th|vi|id|ms|fil)/, '');
const normalizedCleanPath = cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;

// Generate canonical URL (localised for multi-language pages to ensure proper indexing)
const path = normalizedCleanPath.replace(/\/+$/, '/');
const canonicalURL = lang === 'en' 
  ? `https://convertocean.com${path}` 
  : `https://convertocean.com/${lang}${path}`;

// List of all supported locales
const locales = [
  { code: 'en', name: 'English' }
];

const alternates = locales.map(locale => {
  let href = '';
  const path = normalizedCleanPath.replace(/\/+$/, '/');
  if (locale.code === 'en') {
    href = `https://convertocean.com${path}`;
  } else {
    href = `https://convertocean.com/${locale.code}${path}`;
  }
  return { lang: locale.code, href };
});

// JSON-LD Schema Models
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ConvertOcean",
  "url": "https://convertocean.com",
  "logo": "https://convertocean.com/favicon.svg",
  "foundingDate": "2026",
  "description": "An independent, privacy-first suite of client-side file converters, PDF utilities, and business calculators that run entirely in the browser with no server uploads.",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "url": "https://convertocean.com/contact/"
  }
};

const breadcrumbList = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": lang === 'en' ? "https://convertocean.com/" : `https://convertocean.com/${lang}/`
  }
];

if (category && categorySlug) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": 2,
    "name": category,
    "item": lang === 'en' ? `https://convertocean.com/${categorySlug}/` : `https://convertocean.com/${lang}/${categorySlug}/`
  });
}

if (isTool && toolName) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": category ? 3 : 2,
    "name": toolName,
    "item": canonicalURL
  });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbList
};

// SoftwareApplication only on actual tool pages — article-type pages (guides, comparisons) get Article schema instead
const softwareSchema = isTool && !article ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName || title,
  "operatingSystem": "All",
  "applicationCategory": "UtilityApplication",
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD"
  }
} : null;

const articleSchema = article ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.headline,
  "description": description,
  "mainEntityOfPage": canonicalURL,
  "inLanguage": lang,
  ...(article.datePublished ? { "datePublished": article.datePublished } : {}),
  "author": {
    "@type": "Organization",
    "name": "ConvertOcean",
    "url": "https://convertocean.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "ConvertOcean",
    "logo": {
      "@type": "ImageObject",
      "url": "https://convertocean.com/favicon.svg"
    }
  }
} : null;

const faqSchema = faqList && faqList.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqList.map((faq: { q: string; a: string }) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

// Render WebSite schema on the homepage only to optimize search box integration
const websiteSchema = (!category && !isTool) ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ConvertOcean",
  "url": "https://convertocean.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://convertocean.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
} : null;

// Render WebPage schema on all pages to explicitly define metadata
const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": canonicalURL,
  "inLanguage": lang
};


// Helper to prefix links with language prefix if not default 'en'
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7STX0V993V" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-7STX0V993V');
  </script>

  <!--
    Engagement tracking (coTrack).

    This site's promise is that files never leave the device, so the
    analytics must not quietly break it. Nothing here reads file
    contents, and filenames are never sent - only an allowlisted
    extension, a coarse size bucket, and the tool's own path, which
    GA4 already records as page_path. If you are adding an event,
    keep it that way: no names, no contents, no exact byte sizes.

    Inline and early on purpose, so the is:inline scripts inside tool
    components can call window.coTrack without worrying about load order.
  -->
  <script is:inline>
    (function () {
      // Extensions we are willing to report. Anything else becomes
      // 'other', so a strange filename cannot smuggle a value through.
      var KNOWN_EXT = [
        'pdf', 'doc', 'docx', 'xls', 'xlsx', 'csv', 'ppt', 'pptx',
        'txt', 'json', 'xml', 'html', 'md', 'rtf', 'odt',
        'png', 'jpg', 'jpeg', 'webp', 'gif', 'bmp', 'svg', 'heic', 'tiff'
      ];

      function extOf(name) {
        if (typeof name !== 'string') return 'other';
        var dot = name.lastIndexOf('.');
        if (dot < 0) return 'other';
        var ext = name.slice(dot + 1).toLowerCase();
        return KNOWN_EXT.indexOf(ext) === -1 ? 'other' : ext;
      }

      // Coarse buckets only. An exact byte size is close enough to a
      // fingerprint of a specific file that it is not worth sending.
      function sizeBucket(bytes) {
        if (typeof bytes !== 'number' || !isFinite(bytes)) return 'unknown';
        var mb = bytes / (1024 * 1024);
        if (mb < 1) return 'under_1mb';
        if (mb < 5) return '1_5mb';
        if (mb < 20) return '5_20mb';
        if (mb < 50) return '20_50mb';
        return 'over_50mb';
      }

      // The tool's own path. Already collected by GA4 as page_path, so
      // this discloses nothing new - it just makes events readable
      // without a join.
      function toolId() {
        var p = (location.pathname || '/').replace(/^\/+|\/+$/g, '');
        return p === '' ? 'home' : p.slice(0, 100);
      }

      window.coTrack = function (name, params) {
        try {
          if (typeof window.gtag !== 'function') return;
          var payload = { tool: toolId() };
          if (params) {
            for (var k in params) {
              if (Object.prototype.hasOwnProperty.call(params, k)) {
                payload[k] = params[k];
              }
            }
          }
          window.gtag('event', name, payload);
        } catch (e) {
          // Analytics must never break a conversion.
        }
      };

      window.coTrackFiles = function (name, files, extra) {
        var list = files ? Array.prototype.slice.call(files, 0, 50) : [];
        var total = 0;
        for (var i = 0; i < list.length; i++) total += (list[i] && list[i].size) || 0;
        var params = {
          file_count: list.length,
          file_type: list.length ? extOf(list[0].name) : 'other',
          size_bucket: sizeBucket(total)
        };
        if (extra) {
          for (var k in extra) {
            if (Object.prototype.hasOwnProperty.call(extra, k)) params[k] = extra[k];
          }
        }
        window.coTrack(name, params);
      };

      // tool_used - the visitor actually put a file into a tool.
      // One document-level listener in the capture phase covers every
      // file input on the site, including any added later.
      document.addEventListener('change', function (e) {
        var t = e.target;
        if (!t || t.tagName !== 'INPUT' || t.type !== 'file') return;
        if (!t.files || !t.files.length) return;
        window.coTrackFiles('tool_used', t.files, { source: 'picker' });
      }, true);

      // Same signal for drag-and-drop, which never fires a change event.
      document.addEventListener('drop', function (e) {
        var dt = e.dataTransfer;
        if (!dt || !dt.files || !dt.files.length) return;
        window.coTrackFiles('tool_used', dt.files, { source: 'drop' });
      }, true);

      // The calculators, word counter, JSON formatter and generators take
      // typing rather than files, and they recompute on every keystroke.
      // Fire once per page load so the event means "this visitor actually
      // used the tool" instead of counting keypresses.
      var inputCounted = false;
      document.addEventListener('input', function (e) {
        if (inputCounted) return;
        var t = e.target;
        if (!t || !t.tagName) return;
        var tag = t.tagName;
        if (tag !== 'INPUT' && tag !== 'TEXTAREA' && tag !== 'SELECT') return;
        if (tag === 'INPUT' && t.type === 'file') return; // already covered
        // The homepage tool search is navigation, not tool usage.
        if (t.id === 'searchInput' || t.closest('#searchContainer')) return;
        inputCounted = true;
        window.coTrack('tool_used', { source: 'input' });
      }, true);
    })();
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8134957335908795"
     crossorigin="anonymous" is:inline></script>
  
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- Canonical & Alternates -->
  <link rel="canonical" href={canonicalURL} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))}
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <!-- Favicon and App Icons -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="COcean" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://convertocean.com/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="ConvertOcean — convert files without uploading them. 100% in your browser, private, free." />
  <meta property="og:site_name" content="ConvertOcean" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://convertocean.com/og-image.png" />

  <!-- Browser chrome color matches page background per theme -->
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a0a0f" />

  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  )}

  <!-- Pre-render theme code to prevent flashing -->
  <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
      // Enable scroll-reveal ONLY when JS is active, IntersectionObserver
      // is supported, and the user has not requested reduced motion.
      // Otherwise content is never hidden (SEO/no-JS/a11y safe).
      try {
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduce && 'IntersectionObserver' in window) {
          document.documentElement.classList.add('js-reveal');
        }
      } catch (e) {}
    })();
  </script>

  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(webpageSchema)}></script>
  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  )}
  {websiteSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  )}
  {softwareSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
  )}
</head>
<body>
  <div class="hero-glow"></div>

  <Header lang={lang} categorySlug={categorySlug} />

  <slot />

  <Footer lang={lang} />

  <script>
    import '../scripts/theme.js';
  </script>

  <!-- Scroll-reveal observer (no-op unless html.js-reveal is set) -->
  <script is:inline>
    (function () {
      var root = document.documentElement;
      if (!root.classList.contains('js-reveal')) return;
      var els = document.querySelectorAll('[data-reveal], [data-reveal-stagger]');
      if (!els.length) return;
      var reveal = function (el) { el.classList.add('is-visible'); };
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            reveal(entry.target);
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0 });
      els.forEach(function (el) { io.observe(el); });
      // Failsafe: never leave content hidden if the observer misfires.
      window.setTimeout(function () { els.forEach(reveal); }, 3000);
    })();
  </script>
</body>
</html>
