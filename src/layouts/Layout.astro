---
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, lang = 'en', toolName, category, categorySlug, isTool = false, faqList = [] } = Astro.props;

// Determine paths for canonicals and alternates
const canonicalPath = Astro.url.pathname;
const cleanPath = canonicalPath.replace(/^\/(hi|es|fr|de|pt|it|nl|ru|tr|pl|uk|ar|fa|ur|bn|pa|ta|te|mr|gu|zh|ja|ko|th|vi|id|ms|fil)/, '');
const normalizedCleanPath = cleanPath.endsWith('/') ? cleanPath : `${cleanPath}/`;

// Generate canonical URL (localised for multi-language pages to ensure proper indexing)
const path = normalizedCleanPath.replace(/\/+$/, '/');
const canonicalURL = lang === 'en' 
  ? `https://convertocean.com${path}` 
  : `https://convertocean.com/${lang}${path}`;

// List of all supported locales
const locales = [
  { code: 'en', name: 'English' },
  { code: 'hi', name: 'हिन्दी' },
  { code: 'es', name: 'Español' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'pt', name: 'Português' },
  { code: 'it', name: 'Italiano' },
  { code: 'nl', name: 'Nederlands' },
  { code: 'ru', name: 'Русский' },
  { code: 'tr', name: 'Türkçe' },
  { code: 'pl', name: 'Polski' },
  { code: 'uk', name: 'Українська' },
  { code: 'ar', name: 'العربية' },
  { code: 'fa', name: 'فارسی' },
  { code: 'ur', name: 'اردو' },
  { code: 'bn', name: 'বাংলা' },
  { code: 'pa', name: 'ਪੰਜਾਬੀ' },
  { code: 'ta', name: 'தமிழ்' },
  { code: 'te', name: 'తెలుగు' },
  { code: 'mr', name: 'मराठी' },
  { code: 'gu', name: 'ગુજરાતી' },
  { code: 'zh', name: '中文' },
  { code: 'ja', name: '日本語' },
  { code: 'ko', name: '한국어' },
  { code: 'th', name: 'ไทย' },
  { code: 'vi', name: 'Tiếng Việt' },
  { code: 'id', name: 'Bahasa Indonesia' },
  { code: 'ms', name: 'Bahasa Melayu' },
  { code: 'fil', name: 'Filipino' }
];

const alternates = locales.map(locale => {
  let href = '';
  const path = normalizedCleanPath.replace(/\/+$/, '/');
  if (locale.code === 'en') {
    href = `https://convertocean.com${path}`;
  } else {
    href = `https://convertocean.com/${locale.code}${path}`;
  }
  return { lang: locale.code, href };
});

// JSON-LD Schema Models
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "ConvertOcean",
  "url": "https://convertocean.com",
  "logo": "https://convertocean.com/favicon.svg"
};

const breadcrumbList = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": lang === 'en' ? "https://convertocean.com/" : `https://convertocean.com/${lang}/`
  }
];

if (category && categorySlug) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": 2,
    "name": category,
    "item": lang === 'en' ? `https://convertocean.com/${categorySlug}/` : `https://convertocean.com/${lang}/${categorySlug}/`
  });
}

if (isTool && toolName) {
  breadcrumbList.push({
    "@type": "ListItem",
    "position": category ? 3 : 2,
    "name": toolName,
    "item": canonicalURL
  });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbList
};

const softwareSchema = isTool ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": toolName || title,
  "operatingSystem": "All",
  "applicationCategory": "UtilityApplication",
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD"
  }
} : null;

const faqSchema = faqList && faqList.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqList.map((faq: { q: string; a: string }) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

// Render WebSite schema on the homepage only to optimize search box integration
const websiteSchema = (!category && !isTool) ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ConvertOcean",
  "url": "https://convertocean.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://convertocean.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
} : null;

// Render WebPage schema on all pages to explicitly define metadata
const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": canonicalURL,
  "inLanguage": lang
};


// Helper to prefix links with language prefix if not default 'en'
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7STX0V993V" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-7STX0V993V');
  </script>
  
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- Canonical & Alternates -->
  <link rel="canonical" href={canonicalURL} />
  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))}
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <!-- Favicon and App Icons -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="COcean" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://convertocean.com/apple-touch-icon.png" />
  <meta property="og:site_name" content="ConvertOcean" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://convertocean.com/apple-touch-icon.png" />

  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  )}

  <!-- Pre-render theme code to prevent flashing -->
  <script is:inline>
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>

  <!-- Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(webpageSchema)}></script>
  {websiteSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  )}
  {softwareSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
  )}
</head>
<body>
  <div class="hero-glow"></div>

  <Header lang={lang} categorySlug={categorySlug} />

  <slot />

  <Footer lang={lang} />

  <script>
    import '../scripts/theme.js';
  </script>
</body>
</html>
