---
import Layout from '../layouts/Layout.astro';

const { lang = 'en' } = Astro.props;

const title = "500 - Internal Server Error | ConvertOcean";
const description = "Something went wrong with the browser script engine. ConvertOcean runs client-side.";
---

<Layout title={title} description={description} lang={lang} category="500 - Server Error" categorySlug="500">
  <main class="app-container" style="max-width: 800px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; position: relative; z-index: 1;">
    <div style="font-size: 80px; margin-bottom: var(--spacing-md); filter: drop-shadow(0 0 15px rgba(0,0,0,0.05)); font-weight: 700; letter-spacing: -2px; color: var(--colors-ink);">500</div>
    <h1 class="page-title" style="font-size: 32px; font-weight: 600; margin-bottom: var(--spacing-sm); color: var(--colors-ink); letter-spacing: -1px;">Engine error.</h1>
    <p style="font-size: 16px; color: var(--colors-body); max-width: 480px; margin-bottom: var(--spacing-xl); line-height: 1.6;">
      Something went wrong while running the offline compilation scripts in your browser tab cache memory.
    </p>
    <div style="display: flex; gap: var(--spacing-md); justify-content: center; flex-wrap: wrap;">
      <button class="button button-primary" onclick="window.location.reload();" style="display: inline-flex; align-items: center; gap: 8px;">
        Refresh Page
      </button>
      <a href="/" class="button button-secondary" style="display: inline-flex; align-items: center; gap: 8px;">
        Go to Homepage
      </a>
    </div>
  </main>
</Layout>
