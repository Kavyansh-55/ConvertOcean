---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';

import ExcelToPdf from '../components/tools/ExcelToPdf.astro';
import SpreadsheetTool from '../components/tools/SpreadsheetTool.astro';
import ImageTool from '../components/tools/ImageTool.astro';
import TxtToPdf from '../components/tools/TxtToPdf.astro';
import PdfToTxt from '../components/tools/PdfToTxt.astro';
import ImageToText from '../components/tools/ImageToText.astro';
import MergePdf from '../components/tools/MergePdf.astro';
import SplitPdf from '../components/tools/SplitPdf.astro';
import InvoiceGenerator from '../components/tools/InvoiceGenerator.astro';
import WordTool from '../components/tools/WordTool.astro';
import PdfToWord from '../components/tools/PdfToWord.astro';
import PptxTool from '../components/tools/PptxTool.astro';
import PdfToExcel from '../components/tools/PdfToExcel.astro';
import MergeExcel from '../components/tools/MergeExcel.astro';
import SplitExcel from '../components/tools/SplitExcel.astro';
import MergeImages from '../components/tools/MergeImages.astro';
import SplitImage from '../components/tools/SplitImage.astro';
import MergeTxt from '../components/tools/MergeTxt.astro';
import SplitTxt from '../components/tools/SplitTxt.astro';

export function getStaticPaths() {
  return tools.map(t => ({ params: { tool: t.slug } }));
}

const { tool } = Astro.params;
const { lang = 'en' } = Astro.props;

const toolData = tools.find(t => t.slug === tool);
if (!toolData) {
  return Astro.redirect('/');
}

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

// Map component
const toolsMap: Record<string, any> = {
  'excel-to-pdf': ExcelToPdf,
  'csv-to-json': SpreadsheetTool,
  'json-to-csv': SpreadsheetTool,
  'xlsx-to-csv': SpreadsheetTool,
  'csv-to-xlsx': SpreadsheetTool,
  'json-to-xlsx': SpreadsheetTool,
  'xml-to-json': SpreadsheetTool,
  'png-to-jpg': ImageTool,
  'jpg-to-png': ImageTool,
  'png-to-webp': ImageTool,
  'webp-to-png': ImageTool,
  'txt-to-pdf': TxtToPdf,
  'pdf-to-txt': PdfToTxt,
  'image-to-text': ImageToText,
  'merge-pdf': MergePdf,
  'split-pdf': SplitPdf,
  'invoice-generator': InvoiceGenerator,
  'word-to-pdf': WordTool,
  'pdf-to-word': PdfToWord,
  'docx-to-txt': WordTool,
  'pptx-to-pdf': PptxTool,
  'ppt-to-pdf': PptxTool,
  'pdf-to-excel': PdfToExcel,
  'merge-excel': MergeExcel,
  'split-excel': SplitExcel,
  'merge-images': MergeImages,
  'split-image': SplitImage,
  'merge-txt': MergeTxt,
  'split-txt': SplitTxt
};

const ToolComponent = toolsMap[toolData.slug];

// Fetch related tools data
const relatedToolsData = tools.filter(t => toolData.relatedTools.includes(t.slug));

const globalFaqs = [
  {
    q: "How does ConvertOcean convert files without uploading them?",
    a: "ConvertOcean uses WebAssembly (WASM) and local JavaScript compilers to convert files directly inside your browser window. When you load a tool page, all required code is loaded into your browser tab cache, allowing your device's CPU/GPU to parse, compile, and format files locally. Since your file data remains inside sandboxed tab memory, it is never transmitted over the internet or uploaded to a remote server."
  },
  {
    q: "Can a client-side file converter run without an active internet connection?",
    a: "Yes, ConvertOcean is offline-capable. Once you load the tool page in your web browser, all formatting engines, scripts, and WebAssembly converters are stored in your browser tab cache. You can disconnect your device from the internet entirely and convert files locally with 100% functionality and speed."
  },
  {
    q: "Do I need to register an account or pay for a conversion subscription?",
    a: "No registration, signups, or email entries are required. ConvertOcean is 100% free with no conversion limits, no monthly subscriptions, and no paywalls. Every tool is immediately unlocked and ready for secure, private client-side file conversions."
  }
];

const specificFaqs = (toolData.faqs || [])
  .filter(f => 
    !f.question.toLowerCase().includes('upload') && 
    !f.question.toLowerCase().includes('offline') && 
    !f.question.toLowerCase().includes('account') &&
    !f.question.toLowerCase().includes('sign up')
  )
  .map(f => ({ q: f.question, a: f.answer }));

const faqList = [...globalFaqs, ...specificFaqs];
---

<Layout title={toolData.title} description={toolData.description} lang={lang} toolName={toolData.name} category={toolData.category} categorySlug={toolData.categorySlug} isTool={true} faqList={faqList}>
  <style>
    /* Tool Page Specific Styles */
    .steps-section {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-xl);
      margin-top: var(--spacing-3xl);
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }
    @media (max-width: 768px) {
      .steps-grid {
        grid-template-columns: 1fr;
      }
    }
    .step-card {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xxs);
    }
    .step-number {
      font-size: 32px;
      font-weight: 700;
      color: var(--colors-link);
      font-family: 'JetBrains Mono', monospace;
      line-height: 1;
    }
    .step-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--colors-ink);
    }
    .step-desc {
      font-size: 13px;
      color: var(--colors-body);
      line-height: 1.4;
    }

    .features-section {
      margin-top: var(--spacing-3xl);
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }
    @media (max-width: 768px) {
      .features-grid {
        grid-template-columns: 1fr;
      }
    }
    .feature-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.01);
    }
    .feature-icon {
      font-size: 24px;
      margin-bottom: 8px;
    }
    .feature-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-bottom: 4px;
    }
    .feature-desc {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.5;
    }

    .related-section {
      margin-top: var(--spacing-3xl);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-md);
      margin-top: var(--spacing-lg);
    }
    @media (max-width: 768px) {
      .related-grid {
        grid-template-columns: 1fr;
      }
    }
    .related-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      padding: var(--spacing-md);
      text-decoration: none;
      color: var(--colors-ink);
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      transition: transform 0.2s, border-color 0.2s;
    }
    .related-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
    }
    .related-card-icon {
      font-size: 18px;
      width: 32px;
      height: 32px;
      background-color: var(--colors-canvas-soft-2);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .related-card-name {
      font-size: 13.5px;
      font-weight: 600;
    }
  </style>

  <main class="page-container" style="max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); position: relative; z-index: 1;">
    <!-- Active Tool Interface -->
    <ToolComponent slug={toolData.slug} headline={toolData.headline} subtitle={toolData.subtitle} />

    <!-- How It Works Section -->
    <section class="steps-section">
      <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">How It Works</h2>
      <p style="font-size: 14px; color: var(--colors-body); text-align: center; margin-top: 4px;">Four simple steps to process your files securely client-side:</p>
      <div class="steps-grid">
        <div class="step-card">
          <span class="step-number">1.</span>
          <h3 class="step-title">Upload File</h3>
          <p class="step-desc">Drag and drop or browse files directly from your storage. Files reside only in temporary browser memory.</p>
        </div>
        <div class="step-card">
          <span class="step-number">2.</span>
          <h3 class="step-title">Select Output</h3>
          <p class="step-desc">Pick your target conversion configuration or adjust quality/compression sliders according to your preference.</p>
        </div>
        <div class="step-card">
          <span class="step-number">3.</span>
          <h3 class="step-title">Convert Locally</h3>
          <p class="step-desc">All compilers and processors compile files locally in browser sandbox memory. No servers are used.</p>
        </div>
        <div class="step-card">
          <span class="step-number">4.</span>
          <h3 class="step-title">Download Instantly</h3>
          <p class="step-desc">Instantly download your output file. Memory cache is purged automatically when you close the tab.</p>
        </div>
      </div>
    </section>

    <!-- Why Use ConvertOcean Section -->
    <section class="features-section">
      <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">Why Choose ConvertOcean?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3 class="feature-title">Files Stay On Your Device</h3>
          <p class="feature-desc">Traditional sites upload files to external servers. ConvertOcean processes your data 100% locally. Perfect for corporate records and private papers.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3 class="feature-title">Browser-Powered Processing</h3>
          <p class="feature-desc">By eliminating network upload/download queues, conversions run at client-side machine speeds. It continues working even when offline.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🆓</div>
          <h3 class="feature-title">Free & No Accounts</h3>
          <p class="feature-desc">Enjoy unlimited file sizes and conversions. No account creations, no email newsletter subscriptions, and no advertising trackers.</p>
        </div>
      </div>
    </section>

    <!-- Related Tools Section -->
    {relatedToolsData.length > 0 && (
      <section class="related-section">
        <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">Related File Utilities</h2>
        <div class="related-grid">
          {relatedToolsData.map(rt => (
            <a href={relLink(`/${rt.slug}/`)} class="related-card">
              <div class="related-card-icon">{rt.icon}</div>
              <span class="related-card-name">{rt.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- FAQ Accordion Component -->
    {faqList && faqList.length > 0 && (
      <section class="faq-section" style="max-width: 100%; padding: 0; margin-top: var(--spacing-3xl);">
        <h2 class="faq-title" style="font-size: 20px; margin-bottom: var(--spacing-lg);">Frequently Asked Questions</h2>
        <div class="faq-container">
          {faqList.map(faq => (
            <div class="faq-item">
              <div class="faq-question">
                {faq.q}
                <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </div>
              <div class="faq-answer">
                {faq.a}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
