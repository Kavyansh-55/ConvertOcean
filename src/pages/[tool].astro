---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
import { guides } from '../data/guides';
import CategoryIcon from '../components/CategoryIcon.astro';

import ExcelToPdf from '../components/tools/ExcelToPdf.astro';
import SpreadsheetTool from '../components/tools/SpreadsheetTool.astro';
import ImageTool from '../components/tools/ImageTool.astro';
import TxtToPdf from '../components/tools/TxtToPdf.astro';
import PdfToTxt from '../components/tools/PdfToTxt.astro';
import ImageToText from '../components/tools/ImageToText.astro';
import MergePdf from '../components/tools/MergePdf.astro';
import SplitPdf from '../components/tools/SplitPdf.astro';
import InvoiceGenerator from '../components/tools/InvoiceGenerator.astro';
import ReceiptGenerator from '../components/tools/ReceiptGenerator.astro';
import ProfitMarginCalculator from '../components/tools/ProfitMarginCalculator.astro';
import PercentageCalculator from '../components/tools/PercentageCalculator.astro';
import SalesTaxCalculator from '../components/tools/SalesTaxCalculator.astro';
import WordTool from '../components/tools/WordTool.astro';
import PdfToWord from '../components/tools/PdfToWord.astro';
import PptxTool from '../components/tools/PptxTool.astro';
import PdfToExcel from '../components/tools/PdfToExcel.astro';
import MergeExcel from '../components/tools/MergeExcel.astro';
import SplitExcel from '../components/tools/SplitExcel.astro';
import MergeImages from '../components/tools/MergeImages.astro';
import SplitImage from '../components/tools/SplitImage.astro';
import MergeTxt from '../components/tools/MergeTxt.astro';
import SplitTxt from '../components/tools/SplitTxt.astro';
import MergeWord from '../components/tools/MergeWord.astro';
import SplitWord from '../components/tools/SplitWord.astro';
import MergePptx from '../components/tools/MergePptx.astro';
import SplitPptx from '../components/tools/SplitPptx.astro';

export function getStaticPaths() {
  return tools.map(t => ({ params: { tool: t.slug } }));
}

const { tool } = Astro.params;
const { lang = 'en' } = Astro.props;

const toolData = tools.find(t => t.slug === tool);
if (!toolData) {
  return Astro.redirect('/');
}

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

// Map component
const toolsMap: Record<string, any> = {
  'excel-to-pdf': ExcelToPdf,
  'xls-to-pdf': ExcelToPdf,
  'csv-to-pdf': ExcelToPdf,
  'csv-to-json': SpreadsheetTool,
  'json-to-csv': SpreadsheetTool,
  'xlsx-to-csv': SpreadsheetTool,
  'csv-to-xlsx': SpreadsheetTool,
  'json-to-xlsx': SpreadsheetTool,
  'xml-to-json': SpreadsheetTool,
  'xlsx-to-json': SpreadsheetTool,
  'xls-to-json': SpreadsheetTool,
  'xls-to-csv': SpreadsheetTool,
  'xml-to-csv': SpreadsheetTool,
  'xml-to-xlsx': SpreadsheetTool,
  'png-to-jpg': ImageTool,
  'jpg-to-png': ImageTool,
  'png-to-webp': ImageTool,
  'webp-to-png': ImageTool,
  'jpg-to-webp': ImageTool,
  'webp-to-jpg': ImageTool,
  'svg-to-png': ImageTool,
  'svg-to-jpg': ImageTool,
  'svg-to-webp': ImageTool,
  'txt-to-pdf': TxtToPdf,
  'pdf-to-txt': PdfToTxt,
  'image-to-text': ImageToText,
  'merge-pdf': MergePdf,
  'split-pdf': SplitPdf,
  'invoice-generator': InvoiceGenerator,
  'receipt-generator': ReceiptGenerator,
  'profit-margin-calculator': ProfitMarginCalculator,
  'percentage-calculator': PercentageCalculator,
  'sales-tax-calculator': SalesTaxCalculator,
  'word-to-pdf': WordTool,
  'pdf-to-word': PdfToWord,
  'docx-to-txt': WordTool,
  'pptx-to-pdf': PptxTool,
  'ppt-to-pdf': PptxTool,
  'pdf-to-excel': PdfToExcel,
  'merge-excel': MergeExcel,
  'split-excel': SplitExcel,
  'merge-images': MergeImages,
  'split-image': SplitImage,
  'merge-txt': MergeTxt,
  'split-txt': SplitTxt,
  'merge-word': MergeWord,
  'split-word': SplitWord,
  'merge-pptx': MergePptx,
  'split-pptx': SplitPptx
};

const ToolComponent = toolsMap[toolData.slug];

// Fetch related tools data
const relatedToolsData = tools.filter(t => toolData.relatedTools.includes(t.slug));

// Fetch related guides data
const relatedGuides = guides.filter(g => g.relatedTools.includes(toolData.slug));

const globalFaqs = [
  {
    q: "How does ConvertOcean convert files without uploading them?",
    a: "ConvertOcean uses WebAssembly (WASM) and local JavaScript compilers to convert files directly inside your browser window. When you load a tool page, all required code is loaded into your browser tab cache, allowing your device's CPU/GPU to parse, compile, and format files locally. Since your file data remains inside sandboxed tab memory, it is never transmitted over the internet or uploaded to a remote server."
  },
  {
    q: "Can a client-side file converter run without an active internet connection?",
    a: "Yes, ConvertOcean is offline-capable. Once you load the tool page in your web browser, all formatting engines, scripts, and WebAssembly converters are stored in your browser tab cache. You can disconnect your device from the internet entirely and convert files locally with 100% functionality and speed."
  },
  {
    q: "Do I need to register an account or pay for a conversion subscription?",
    a: "No registration, signups, or email entries are required. ConvertOcean is 100% free with no conversion limits, no monthly subscriptions, and no paywalls. Every tool is immediately unlocked and ready for secure, private client-side file conversions."
  }
];

const specificFaqs = (toolData.faqs || [])
  .filter(f => 
    !f.question.toLowerCase().includes('upload') && 
    !f.question.toLowerCase().includes('offline') && 
    !f.question.toLowerCase().includes('account') &&
    !f.question.toLowerCase().includes('sign up')
  )
  .map(f => ({ q: f.question, a: f.answer }));

const faqList = [...globalFaqs, ...specificFaqs];
---

<Layout title={toolData.title} description={toolData.description} lang={lang} toolName={toolData.name} category={toolData.category} categorySlug={toolData.categorySlug} isTool={true} faqList={faqList}>
  <style>
    /* Tool Page Specific Styles */
    .steps-section {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-xl);
      margin-top: var(--spacing-3xl);
    }
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }
    @media (max-width: 768px) {
      .steps-grid {
        grid-template-columns: 1fr;
      }
    }
    .step-card {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xxs);
    }
    .step-number {
      font-size: 32px;
      font-weight: 700;
      color: var(--colors-link);
      font-family: 'JetBrains Mono', monospace;
      line-height: 1;
    }
    .step-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--colors-ink);
    }
    .step-desc {
      font-size: 13px;
      color: var(--colors-body);
      line-height: 1.4;
    }

    .features-section {
      margin-top: var(--spacing-3xl);
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }
    @media (max-width: 768px) {
      .features-grid {
        grid-template-columns: 1fr;
      }
    }
    .feature-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.01), inset 0px 0px 0px 1px var(--colors-hairline);
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04), inset 0px 0px 0px 1px var(--colors-hairline-strong);
    }
    .feature-icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: var(--rounded-md);
      background-color: var(--colors-canvas-soft-2);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: var(--spacing-xxs);
      transition: background-color 0.3s, transform 0.25s ease;
      border: 1px solid var(--colors-hairline);
      flex-shrink: 0;
    }
    [data-theme="dark"] .feature-icon-wrapper {
      background-color: rgba(255, 255, 255, 0.03);
    }
    .feature-card:hover .feature-icon-wrapper {
      transform: scale(1.05);
      background-color: var(--colors-canvas);
    }
    .feature-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-bottom: 4px;
    }
    .feature-desc {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.5;
    }

    .related-section {
      margin-top: var(--spacing-3xl);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-md);
      margin-top: var(--spacing-lg);
    }
    @media (max-width: 768px) {
      .related-grid {
        grid-template-columns: 1fr;
      }
    }
    .related-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      padding: var(--spacing-md);
      text-decoration: none;
      color: var(--colors-ink);
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
      transition: transform 0.2s, border-color 0.2s;
    }
    .related-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
    }
    .related-card-icon {
      font-size: 18px;
      width: 32px;
      height: 32px;
      background-color: var(--colors-canvas-soft-2);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .related-card-name {
      font-size: 13.5px;
      font-weight: 600;
    }
    
    /* Unique SEO Article Content Styles */
    .rich-text {
      font-size: 14.5px;
      line-height: 1.7;
      color: var(--colors-body);
      margin-top: var(--spacing-3xl);
    }
    .rich-text h2 {
      font-size: 24px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-top: var(--spacing-xl);
      margin-bottom: var(--spacing-md);
      letter-spacing: -0.96px;
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }
    .rich-text h3 {
      font-size: 18px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-top: var(--spacing-lg);
      margin-bottom: var(--spacing-sm);
      letter-spacing: -0.6px;
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }
    .rich-text p {
      margin-bottom: var(--spacing-md);
    }
    .rich-text ul {
      margin-bottom: var(--spacing-md);
      padding-left: var(--spacing-lg);
      list-style-type: disc;
    }
    .rich-text li {
      margin-bottom: var(--spacing-xs);
    }
    .rich-text blockquote {
      border-left: 3px solid var(--colors-link);
      padding: var(--spacing-sm) var(--spacing-md);
      margin: var(--spacing-md) 0;
      font-style: italic;
      color: var(--colors-ink);
      background-color: var(--colors-canvas-soft-2);
      border-radius: var(--rounded-sm);
    }
    .rich-text a {
      color: var(--colors-link);
      text-decoration: underline;
      transition: color 0.2s;
    }
    .rich-text a:hover {
      color: var(--colors-link-deep);
    }
    .rich-text code {
      font-family: 'JetBrains Mono', monospace;
      background-color: var(--colors-canvas-soft-2);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 13px;
    }
    .rich-text .content-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-xl);
      margin-top: var(--spacing-xl);
    }

    /* Related Guides Section Conforming to DESIGN.md */
    .related-guides-section {
      margin-top: var(--spacing-3xl);
    }
    .related-guides-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--spacing-md);
      margin-top: var(--spacing-lg);
    }
    .tool-related-guide-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      padding: var(--spacing-md);
      text-decoration: none;
      color: var(--colors-ink);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .tool-related-guide-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.03);
    }
    .tool-related-guide-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      color: var(--colors-link);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }
    .tool-related-guide-name {
      font-size: 14.5px;
      font-weight: 600;
      line-height: 1.3;
      margin: 0;
    }
    .tool-related-guide-desc {
      font-size: 12.5px;
      color: var(--colors-body);
      line-height: 1.4;
      margin: 0;
    }
    .tool-related-guide-action {
      font-size: 12px;
      color: var(--colors-link);
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 2px;
      margin-top: auto;
      padding-top: var(--spacing-xxs);
    }
  </style>

  <main class="page-container" style="max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); position: relative; z-index: 1;">
    <!-- Active Tool Interface -->
    <ToolComponent slug={toolData.slug} headline={toolData.headline} subtitle={toolData.subtitle} />

    <!-- How It Works Section -->
    {toolData.categorySlug !== 'business-tools' && (
      <section class="steps-section">
        <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">How It Works</h2>
        <p style="font-size: 14px; color: var(--colors-body); text-align: center; margin-top: 4px;">Four simple steps to process your files securely client-side:</p>
        <div class="steps-grid">
          <div class="step-card">
            <span class="step-number">1.</span>
            <h3 class="step-title">Upload File</h3>
            <p class="step-desc">Drag and drop or browse files directly from your storage. Files reside only in temporary browser memory.</p>
          </div>
          <div class="step-card">
            <span class="step-number">2.</span>
            <h3 class="step-title">Select Output</h3>
            <p class="step-desc">Pick your target conversion configuration or adjust quality/compression sliders according to your preference.</p>
          </div>
          <div class="step-card">
            <span class="step-number">3.</span>
            <h3 class="step-title">Convert Locally</h3>
            <p class="step-desc">All compilers and processors compile files locally in browser sandbox memory. No servers are used.</p>
          </div>
          <div class="step-card">
            <span class="step-number">4.</span>
            <h3 class="step-title">Download Instantly</h3>
            <p class="step-desc">Instantly download your output file. Memory cache is purged automatically when you close the tab.</p>
          </div>
        </div>
      </section>
    )}

    <!-- Unique SEO Article Content Section -->
    {toolData.content && (
      <section class="rich-text" set:html={toolData.content}></section>
    )}

    <!-- Why Use ConvertOcean Section -->
    <section class="features-section">
      <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">Why Choose ConvertOcean?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #0070f3;"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3 class="feature-title">Files Stay On Your Device</h3>
          <p class="feature-desc">Traditional sites upload files to external servers. ConvertOcean processes your data 100% locally. Perfect for corporate records and private papers.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #f5a623;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="feature-title">Browser-Powered Processing</h3>
          <p class="feature-desc">By eliminating network upload/download queues, conversions run at client-side machine speeds. It continues working even when offline.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #7928ca;"><rect width="18" height="14" x="3" y="8" rx="2"/><path d="M12 5a3 3 0 1 0-3 3h6a3 3 0 1 0-3-3Z"/><path d="M12 8v14"/><path d="M3 12h18"/></svg>
          </div>
          <h3 class="feature-title">Free & No Accounts</h3>
          <p class="feature-desc">Enjoy unlimited file sizes and conversions. No account creations, no email newsletter subscriptions, and no advertising trackers.</p>
        </div>
      </div>
    </section>

    <!-- Related Tools Section -->
    {relatedToolsData.length > 0 && (
      <section class="related-section">
        <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">Related File Utilities</h2>
        <div class="related-grid">
          {relatedToolsData.map(rt => (
            <a href={relLink(`/${rt.slug}/`)} class="related-card">
              <div class="related-card-icon" style="color: var(--colors-ink);">
                <CategoryIcon icon={rt.icon} width="18" height="18" />
              </div>
              <span class="related-card-name">{rt.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related Guides & Resources Section -->
    {relatedGuides.length > 0 && (
      <section class="related-guides-section">
        <h2 style="font-size: 20px; font-weight: 600; color: var(--colors-ink); text-align: center;">Related Guides & Resources.</h2>
        <div class="related-guides-grid">
          {relatedGuides.map(g => (
            <a href={relLink(`/guides/${g.slug}/`)} class="tool-related-guide-card">
              <span class="tool-related-guide-tag">Guide</span>
              <h3 class="tool-related-guide-name">{g.title.split(' - ')[0]}</h3>
              <p class="tool-related-guide-desc">{g.description}</p>
              <span class="tool-related-guide-action">
                Read Guide
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- FAQ Accordion Component -->
    {faqList && faqList.length > 0 && (
      <section class="faq-section" style="max-width: 100%; padding: 0; margin-top: var(--spacing-3xl);">
        <h2 class="faq-title" style="font-size: 20px; margin-bottom: var(--spacing-lg);">Frequently Asked Questions</h2>
        <div class="faq-container">
          {faqList.map(faq => (
            <div class="faq-item">
              <div class="faq-question">
                {faq.q}
                <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </div>
              <div class="faq-answer">
                {faq.a}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
