    /* ─── Hero: bolder oceanic mesh-gradient, weighted behind the product panel ─── */
    .hero-container::before {
      content: "";
      position: absolute;
      top: -80px;
      left: 50%;
      transform: translateX(-50%);
      width: 1200px;
      max-width: 140%;
      height: 560px;
      background:
        radial-gradient(closest-side at 30% 42%, rgba(0, 112, 243, 0.20), transparent 72%),
        radial-gradient(closest-side at 66% 30%, rgba(0, 223, 216, 0.26), transparent 72%),
        radial-gradient(closest-side at 80% 62%, rgba(80, 227, 194, 0.22), transparent 72%),
        radial-gradient(closest-side at 52% 74%, rgba(0, 124, 240, 0.16), transparent 72%);
      filter: blur(50px);
      z-index: -1;
      pointer-events: none;
    }
    [data-theme="dark"] .hero-container::before {
      background:
        radial-gradient(closest-side at 30% 42%, rgba(0, 112, 243, 0.36), transparent 72%),
        radial-gradient(closest-side at 66% 30%, rgba(0, 223, 216, 0.40), transparent 72%),
        radial-gradient(closest-side at 80% 62%, rgba(80, 227, 194, 0.32), transparent 72%),
        radial-gradient(closest-side at 52% 74%, rgba(0, 124, 240, 0.26), transparent 72%);
    }

    /* ─── Split hero layout ─── */
    /* Two columns on desktop, one on mobile. .hero-lead is display:contents
       so its children are grid items directly — that lets the dropzone sit in
       column 2 on desktop while keeping a single, correct DOM order for
       mobile reading and focus sequence. */
    .hero-split {
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      column-gap: var(--spacing-3xl);
      align-items: center;
      text-align: left;
    }
    .hero-lead { display: contents; }

    /* Rows are assigned explicitly: `grid-row: 1 / -1` cannot span
       implicit rows (-1 resolves against the explicit grid, which would
       leave the panel stuck in row 1 and stretch it). */
    /* Grid items stretch by default; the pill must hug its text. */
    .hero-status            { grid-area: 1 / 1; justify-self: start; }
    .hero-title             { grid-area: 2 / 1; }
    .hero-subtitle          { grid-area: 3 / 1; }
    .hero-split .search-container  { grid-area: 4 / 1; }
    .hero-split .popular-searches  { grid-area: 5 / 1; }
    .hero-split .hero-cta-group    { grid-area: 6 / 1; }

    .hero-status,
    .hero-title,
    .hero-subtitle,
    .hero-split .search-container,
    .hero-split .popular-searches,
    .hero-split .hero-cta-group { min-width: 0; }

    .hero-panel-col {
      grid-column: 2;
      grid-row: 1 / 7;
      align-self: center;
      min-width: 0;
    }

    .hero-split .search-container { margin-left: 0; margin-right: 0; max-width: 560px; }
    .hero-split .popular-searches { justify-content: flex-start; }
    .hero-split .hero-cta-group { justify-content: flex-start; }

    @media (max-width: 940px) {
