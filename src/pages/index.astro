---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
import { guides } from '../data/guides';
import CategoryIcon from '../components/CategoryIcon.astro';

const { lang = 'en' } = Astro.props;

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

const title = "ConvertOcean - 100% Private Offline File Converter & Web Utilities";
const description = "Securely convert, merge, split, and extract text from files client-side. Operating 100% locally in your browser sandbox with zero server uploads and complete privacy.";

const faqList = [
  {
    q: "How does ConvertOcean convert files without uploading them?",
    a: "ConvertOcean uses WebAssembly (WASM) and local JavaScript compilers to convert files directly inside your browser window. When you load a tool page, all required code is loaded into your browser tab cache, allowing your device's CPU/GPU to parse, compile, and format files locally. Since your file data remains inside sandboxed tab memory, it is never transmitted over the internet or uploaded to a remote server."
  },
  {
    q: "Is my confidential business or financial data safe when converting files?",
    a: "Yes, converting sensitive files on ConvertOcean is completely safe. Because all data processing happens locally on your device (client-side), confidential documents, financial statements, internal spreadsheet formulas, and tax details are never uploaded to any remote server or third-party database. You retain full data sovereignty at all times."
  },
  {
    q: "Can a client-side file converter run without an active internet connection?",
    a: "Yes, ConvertOcean is offline-capable. Once you load the tool page in your web browser, all formatting engines, scripts, and WebAssembly converters are stored in your browser tab cache. You can disconnect your device from the internet entirely and convert files locally with 100% functionality and speed."
  },
  {
    q: "Are files stored temporarily on your servers or cookies?",
    a: "No. ConvertOcean does not utilize remote servers for file processing or data storage. All file contents and parsed values reside temporarily in sandboxed browser memory. Once you download the converted file or close the web browser tab, all temporary data is instantly and permanently purged from your device's RAM."
  },
  {
    q: "Does ConvertOcean collect any user telemetry or conversion metadata?",
    a: "No. ConvertOcean does not track user activities, store analytics telemetry, use tracking cookies, or collect file metadata (such as names, sizes, or paths). Our tools are strictly client-side static assets, ensuring complete user privacy and anonymity without email logins or server logs."
  },
  {
    q: "Do I need to register an account or pay for a conversion subscription?",
    a: "No registration, signups, or email entries are required. ConvertOcean is 100% free with no conversion limits, no monthly subscriptions, and no paywalls. Every tool is immediately unlocked and ready for secure, private client-side file conversions."
  }
];

const getToolCount = (categorySlug: string) => {
  if (categorySlug === 'file-converter') {
    return 30; // 30+ formats
  }
  if (categorySlug === 'pdf-tools') {
    return tools.filter(t =>
      t.categorySlug === 'pdf-tools' ||
      t.slug.toLowerCase().includes('pdf') ||
      t.name.toLowerCase().includes('pdf') ||
      t.slug.toLowerCase().includes('merge') ||
      t.slug.toLowerCase().includes('split')
    ).length;
  }
  return tools.filter(t => t.categorySlug === categorySlug).length;
};

// Per-category accent (from the brand gradient palette) — used to colour tool + category tiles.
const categoryAccent: Record<string, string> = {
  'pdf-tools': '#ff4d4d',
  'image-tools': '#7928ca',
  'excel-converter': '#29bc9b',
  'document-tools': '#0070f3',
  'developer-tools': '#007cf0',
  'business-tools': '#f5a623',
};
const accentFor = (slug: string, cat: string) => categoryAccent[cat] || '#0070f3';

// Curated "most-used" tools for the homepage — high-intent, one-tap entry.
const popularSlugs = ['pdf-to-word', 'excel-to-pdf', 'image-resizer', 'merge-pdf', 'jpg-to-png', 'image-to-text', 'word-to-pdf', 'split-pdf'];
const popularTools = popularSlugs
  .map(s => tools.find(t => t.slug === s))
  .filter((t): t is (typeof tools)[number] => Boolean(t));

// Representative tools for the hero product-panel — one per major category, so the
// panel shows the breadth of the whole toolkit at a glance (auto-updates with the data).
const panelSlugs = ['pdf-to-word', 'jpg-to-png', 'excel-to-pdf', 'csv-to-json', 'merge-pdf', 'break-even-calculator'];
const panelTools = panelSlugs
  .map(s => tools.find(t => t.slug === s))
  .filter((t): t is (typeof tools)[number] => Boolean(t));

// Nicer chip labels for format tokens (honest — only real formats).
const fmtLabels: Record<string, string> = {
  jpg: 'JPG', jpeg: 'JPG', png: 'PNG', webp: 'WEBP', svg: 'SVG', gif: 'GIF',
  pdf: 'PDF', word: 'DOCX', docx: 'DOCX', ppt: 'PPT', pptx: 'PPTX',
  excel: 'XLSX', xls: 'XLS', xlsx: 'XLSX', csv: 'CSV', json: 'JSON', xml: 'XML',
  txt: 'TXT', image: 'IMG', text: 'TEXT',
};
const chipLabel = (tok: string) => fmtLabels[tok] || tok.toUpperCase();

// Derive scannable chips from a tool slug: a format pair (A → B), or a single action/format chip.
type ToolChips = { pair: true; from: string; to: string } | { pair: false; single: string };
const toolChips = (slug: string): ToolChips => {
  const m = slug.match(/^(.+)-to-(.+)$/);
  if (m) return { pair: true, from: chipLabel(m[1]), to: chipLabel(m[2]) };
  if (slug.startsWith('merge-')) return { pair: false, single: 'MERGE' };
  if (slug.startsWith('split-')) return { pair: false, single: 'SPLIT' };
  if (slug.endsWith('-calculator')) return { pair: false, single: 'CALC' };
  if (slug.endsWith('-generator')) return { pair: false, single: 'PDF' };
  if (slug === 'image-resizer') return { pair: false, single: 'RESIZE' };
  if (slug === 'word-counter') return { pair: false, single: 'COUNT' };
  if (slug === 'json-formatter') return { pair: false, single: 'JSON' };
  return { pair: false, single: chipLabel(slug.split('-')[0]) };
};

---

<Layout title={title} description={description} lang={lang} faqList={faqList}>
  <style>
    /* Homepage Specific CSS */
    .hero-container {
      max-width: 1180px;
      margin: 0 auto;
      padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-2xl);
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .hero-title {
      font-size: 56px;
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -2.6px;
      margin-bottom: var(--spacing-md);
      color: var(--colors-ink);
    }

    .hero-title-accent {
      background: linear-gradient(90deg, #007cf0, #00dfd8, #007cf0);
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      display: inline-block;
      animation: accent-pan 6s ease-in-out infinite;
    }

    @keyframes accent-pan {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-title-accent { animation: none; }
    }

    @media (max-width: 768px) {
      .hero-title {
        font-size: 38px;
        letter-spacing: -1.6px;
      }
    }

    @media (max-width: 420px) {
      .hero-title {
        font-size: 30px;
        letter-spacing: -1.2px;
      }
    }

    .hero-subtitle {
      font-size: 19px;
      color: var(--colors-body);
      max-width: 680px;
      margin: 0 auto var(--spacing-lg);
      line-height: 1.6;
    }

    @media (max-width: 480px) {
      .hero-subtitle {
        font-size: 15.5px;
      }
    }

    .hero-cta-group {
      display: flex;
      justify-content: center;
      gap: var(--spacing-md);
      margin-bottom: var(--spacing-2xl);
    }

    /* Hide /⌘K kbd hint on touch devices — no keyboard shortcut */
    @media (max-width: 640px) {
      .search-kbd {
        display: none;
      }
    }

  </style>
  <style is:global>
    /* Premium Autocomplete Search Bar */
    .search-container {
      position: relative;
      max-width: 600px;
      width: 100%;
      margin: var(--spacing-xl) auto;
      z-index: 10;
    }

    .search-input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      border-radius: var(--rounded-lg);
      background-color: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(8px);
      border: 1px solid var(--colors-hairline);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .search-input-wrapper:focus-within {
      border-color: rgba(0, 112, 243, 0.45);
      box-shadow: 0 0 0 3px rgba(0, 112, 243, 0.12), 0 10px 40px rgba(0, 0, 0, 0.06);
      transform: translateY(-1px);
    }

    [data-theme="dark"] .search-input-wrapper {
      background-color: rgba(18, 18, 18, 0.8);
      backdrop-filter: blur(8px);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
    }

    [data-theme="dark"] .search-input-wrapper:focus-within {
      border-color: rgba(0, 223, 216, 0.45);
      box-shadow: 0 0 0 3px rgba(0, 223, 216, 0.18), 0 10px 40px rgba(0, 0, 0, 0.35);
    }

    .search-icon {
      position: absolute;
      left: var(--spacing-md);
      color: var(--colors-mute);
      pointer-events: none;
      font-size: 18px;
      display: flex;
      align-items: center;
    }

    .search-input {
      width: 100%;
      padding: 16px var(--spacing-md) 16px 48px;
      font-size: 16px;
      border: none;
      background: transparent;
      color: var(--colors-ink);
      outline: none;
      box-shadow: none !important;
    }

    .search-kbd {
      position: absolute;
      right: var(--spacing-md);
      background: var(--colors-canvas-soft-2);
      border: 1px solid var(--colors-hairline);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 11px;
      font-family: inherit;
      color: var(--colors-mute);
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .search-input-wrapper:focus-within .search-kbd {
      opacity: 0;
    }

    [data-theme="dark"] .search-kbd {
      background: rgba(255, 255, 255, 0.05);
    }

    /* Results Dropdown */
    .search-results-panel {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background-color: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(12px);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      max-height: 380px;
      overflow-y: auto;
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.08);
      display: none;
      flex-direction: column;
      z-index: 999;
      padding: var(--spacing-xs) 0;
      animation: dropdown-fade-in 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-theme="dark"] .search-results-panel {
      background-color: rgba(18, 18, 18, 0.95);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.4);
    }

    .search-result-item {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding: var(--spacing-sm) var(--spacing-md);
      text-decoration: none;
      color: var(--colors-ink);
      transition: all 0.2s ease;
      margin: 2px var(--spacing-xs);
      border-radius: var(--rounded-sm);
    }

    .search-result-item:hover, .search-result-item.selected {
      background-color: var(--colors-canvas-soft-2);
      transform: translateX(4px);
    }

    [data-theme="dark"] .search-result-item:hover, [data-theme="dark"] .search-result-item.selected {
      background-color: rgba(255, 255, 255, 0.05);
    }

    .search-result-icon {
      font-size: 20px;
      width: 38px;
      height: 38px;
      border-radius: 8px;
      background-color: var(--colors-canvas-soft-2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--colors-hairline);
    }

    [data-theme="dark"] .search-result-icon {
      background-color: rgba(255, 255, 255, 0.03);
    }

    .search-result-info {
      display: flex;
      flex-direction: column;
      text-align: left;
    }

    .search-result-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--colors-ink);
    }

    .search-result-desc {
      font-size: 11.5px;
      color: var(--colors-mute);
      margin-top: 1px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 440px;
    }
  </style>
  <style>

    /* Trust section */
    .trust-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-4xl);
      padding: 0 var(--spacing-lg);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-lg);
    }

    @media (max-width: 900px) {
      .trust-section {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .trust-section {
        grid-template-columns: 1fr;
      }
    }

    .trust-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      text-align: left;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02), inset 0px 0px 0px 1px var(--colors-hairline);
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .trust-card:hover {
      transform: translateY(-4px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04), inset 0px 0px 0px 1px var(--colors-hairline-strong);
    }

    .trust-icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: var(--rounded-md);
      background-color: var(--colors-canvas-soft-2);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: var(--spacing-xxs);
      transition: background-color 0.3s, transform 0.25s ease;
      border: 1px solid var(--colors-hairline);
    }

    [data-theme="dark"] .trust-icon-wrapper {
      background-color: rgba(255, 255, 255, 0.03);
    }

    .trust-card:hover .trust-icon-wrapper {
      transform: scale(1.05);
      background-color: var(--colors-canvas);
    }

    .trust-title {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--colors-ink);
    }

    .trust-desc {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.5;
    }

    .section-divider {
      max-width: 1200px;
      margin: 0 auto var(--spacing-3xl);
      border: 0;
      height: 1px;
      background-color: var(--colors-hairline);
    }

    /* Popular Searches Styling */
    .popular-searches {
      margin-top: var(--spacing-md);
      font-size: 13.5px;
      color: var(--colors-body);
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
    }
    .popular-searches-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--colors-mute);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-right: 4px;
    }
    .popular-search-link {
      color: var(--colors-link);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }
    .popular-search-link:hover {
      color: var(--colors-link-deep);
      text-decoration: underline;
    }
    .popular-search-separator {
      color: var(--colors-hairline-strong);
      user-select: none;
      margin: 0 2px;
    }

    /* Featured Tools Styling */
    .featured-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-4xl);
      padding: 0 var(--spacing-lg);
    }
    .featured-title {
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -1.2px;
      margin-bottom: var(--spacing-xl);
      color: var(--colors-ink);
      text-align: center;
    }
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
    }
    @media (max-width: 900px) {
      .featured-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 600px) {
      .featured-grid {
        grid-template-columns: 1fr;
      }
    }
    .featured-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      position: relative;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.02), inset 0px 0px 0px 1px var(--colors-hairline);
    }
    .featured-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.05), inset 0px 0px 0px 1px var(--colors-hairline-strong);
    }
    .featured-badge {
      align-self: flex-start;
      font-size: 11px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: var(--rounded-pill);
      background-color: var(--colors-canvas-soft-2);
      color: var(--colors-body);
      font-family: 'JetBrains Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.2px;
    }
    [data-theme="dark"] .featured-badge {
      background-color: rgba(255, 255, 255, 0.05);
    }
    .featured-card-header {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
    }
    .featured-card-icon {
      font-size: 24px;
      width: 44px;
      height: 44px;
      background-color: var(--colors-canvas-soft-2);
      border-radius: var(--rounded-md);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--colors-hairline);
    }
    [data-theme="dark"] .featured-card-icon {
      background-color: rgba(255, 255, 255, 0.03);
    }
    .featured-card-name {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -0.4px;
      color: var(--colors-ink);
      margin: 0;
    }
    .featured-card-desc {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.5;
      flex-grow: 1;
      margin: 0;
    }
    .featured-cta {
      align-self: flex-start;
      margin-top: var(--spacing-xs);
    }

    /* Comparison Table Styling */
    .comparison-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-4xl);
      padding: 0 var(--spacing-lg);
      text-align: center;
    }
    .comparison-title {
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -1.2px;
      color: var(--colors-ink);
      margin-bottom: var(--spacing-xs);
    }
    .comparison-subtitle {
      font-size: 15px;
      color: var(--colors-body);
      max-width: 600px;
      margin: 0 auto var(--spacing-xl);
      line-height: 1.5;
    }
    .table-wrapper {
      overflow-x: auto;
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      background-color: var(--colors-canvas);
      box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.01);
    }
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 14.5px;
    }
    .comparison-table th, 
    .comparison-table td {
      padding: var(--spacing-md) var(--spacing-lg);
      border-bottom: 1px solid var(--colors-hairline);
    }
    .comparison-table th {
      font-weight: 600;
      color: var(--colors-ink);
      background-color: var(--colors-canvas-soft-2);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    [data-theme="dark"] .comparison-table th {
      background-color: rgba(255, 255, 255, 0.02);
    }
    .comparison-table tr:last-child td {
      border-bottom: none;
    }
    .feature-name {
      font-weight: 500;
      color: var(--colors-ink);
    }
    .col-highlight {
      background-color: rgba(0, 223, 216, 0.02);
      font-weight: 600;
    }
    [data-theme="dark"] .col-highlight {
      background-color: rgba(0, 223, 216, 0.04);
    }
    .text-success {
      color: #00dfd8;
      font-weight: 700;
      font-size: 18px;
    }
    .text-danger {
      color: var(--colors-mute);
      font-size: 16px;
    }
    .category-count {
      font-size: 14px;
      font-weight: 500;
      color: var(--colors-mute);
      margin-left: 6px;
    }

    /* ─── Hero: bolder oceanic mesh-gradient, weighted behind the product panel ─── */
    .hero-container::before {
      content: "";
      position: absolute;
      top: -80px;
      left: 50%;
      transform: translateX(-50%);
      width: 1200px;
      max-width: 140%;
      height: 560px;
      background:
        radial-gradient(closest-side at 30% 42%, rgba(0, 112, 243, 0.20), transparent 72%),
        radial-gradient(closest-side at 66% 30%, rgba(0, 223, 216, 0.26), transparent 72%),
        radial-gradient(closest-side at 80% 62%, rgba(80, 227, 194, 0.22), transparent 72%),
        radial-gradient(closest-side at 52% 74%, rgba(0, 124, 240, 0.16), transparent 72%);
      filter: blur(50px);
      z-index: -1;
      pointer-events: none;
    }
    [data-theme="dark"] .hero-container::before {
      background:
        radial-gradient(closest-side at 30% 42%, rgba(0, 112, 243, 0.36), transparent 72%),
        radial-gradient(closest-side at 66% 30%, rgba(0, 223, 216, 0.40), transparent 72%),
        radial-gradient(closest-side at 80% 62%, rgba(80, 227, 194, 0.32), transparent 72%),
        radial-gradient(closest-side at 52% 74%, rgba(0, 124, 240, 0.26), transparent 72%);
    }

    /* ─── Split hero layout ─── */
    .hero-split {
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      gap: var(--spacing-3xl);
      align-items: center;
      text-align: left;
    }
    .hero-lead { min-width: 0; }
    /* left-align the lead elements that are otherwise centered */
    .hero-lead .search-container { margin-left: 0; margin-right: 0; max-width: 560px; }
    .hero-lead .popular-searches { justify-content: flex-start; }
    .hero-lead .hero-cta-group { justify-content: flex-start; }
    @media (max-width: 940px) {
