      .hero-split {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
        text-align: center;
      }
      .hero-status, .hero-title, .hero-subtitle,
      .hero-split .search-container, .hero-split .popular-searches,
      .hero-split .hero-cta-group, .hero-panel-col { grid-area: auto; }
      .hero-status { align-self: center; }
      .hero-panel-col { max-width: 440px; width: 100%; margin: 0 auto; }
      .hero-split .search-container { margin-left: auto; margin-right: auto; }
      .hero-split .popular-searches { justify-content: center; }
      .hero-split .hero-cta-group { justify-content: center; }
    }



    /* ─── Delicate ocean wave at the hero's base (atmosphere) ─── */

