---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
import { guides } from '../data/guides';
import CategoryIcon from '../components/CategoryIcon.astro';
import HeroDropzone from '../components/HeroDropzone.astro';
import CategoryCard from '../components/CategoryCard.astro';

const { lang = 'en' } = Astro.props;

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

const title = "ConvertOcean - 100% Private Offline File Converter & Web Utilities";
const description = "Securely convert, merge, split, and extract text from files client-side. Operating 100% locally in your browser sandbox with zero server uploads and complete privacy.";

const faqList = [
  {
    q: "How does ConvertOcean convert files without uploading them?",
    a: "ConvertOcean uses WebAssembly (WASM) and local JavaScript compilers to convert files directly inside your browser window. When you load a tool page, all required code is loaded into your browser tab cache, allowing your device's CPU/GPU to parse, compile, and format files locally. Since your file data remains inside sandboxed tab memory, it is never transmitted over the internet or uploaded to a remote server."
  },
  {
    q: "Is my confidential business or financial data safe when converting files?",
    a: "Yes, converting sensitive files on ConvertOcean is completely safe. Because all data processing happens locally on your device (client-side), confidential documents, financial statements, internal spreadsheet formulas, and tax details are never uploaded to any remote server or third-party database. You retain full data sovereignty at all times."
  },
  {
    q: "Can a client-side file converter run without an active internet connection?",
    a: "Yes, ConvertOcean is offline-capable. Once you load the tool page in your web browser, all formatting engines, scripts, and WebAssembly converters are stored in your browser tab cache. You can disconnect your device from the internet entirely and convert files locally with 100% functionality and speed."
  },
  {
    q: "Are files stored temporarily on your servers or cookies?",
    a: "No. ConvertOcean does not utilize remote servers for file processing or data storage. All file contents and parsed values reside temporarily in sandboxed browser memory. Once you download the converted file or close the web browser tab, all temporary data is instantly and permanently purged from your device's RAM."
  },
  {
    q: "Does ConvertOcean collect any user telemetry or conversion metadata?",
    a: "No. ConvertOcean does not track user activities, store analytics telemetry, use tracking cookies, or collect file metadata (such as names, sizes, or paths). Our tools are strictly client-side static assets, ensuring complete user privacy and anonymity without email logins or server logs."
  },
  {
    q: "Do I need to register an account or pay for a conversion subscription?",
    a: "No registration, signups, or email entries are required. ConvertOcean is 100% free with no conversion limits, no monthly subscriptions, and no paywalls. Every tool is immediately unlocked and ready for secure, private client-side file conversions."
  }
];

const getToolCount = (categorySlug: string) => {
  if (categorySlug === 'file-converter') {
    return 30; // 30+ formats
  }
  if (categorySlug === 'pdf-tools') {
    return tools.filter(t =>
      t.categorySlug === 'pdf-tools' ||
      t.slug.toLowerCase().includes('pdf') ||
      t.name.toLowerCase().includes('pdf') ||
      t.slug.toLowerCase().includes('merge') ||
      t.slug.toLowerCase().includes('split')
    ).length;
  }
  return tools.filter(t => t.categorySlug === categorySlug).length;
};

// One accent, not six. The per-category hues (red / violet / green / blue /
// amber) were decorative — a card's category is already carried by the filter
// tabs and the tool name — and six competing hues on one grid is what made the
// page read as assembled rather than designed. Colour now lives in CSS as a
// single token; nothing is bound per card.

// Curated "most-used" tools for the homepage — high-intent, one-tap entry.
// Category tiles, in bento order — position determines tile size, so this
// array is the single place that ordering lives.
const categoryCards = [
  {
    href: '/file-converter/', categorySlug: 'file-converter',
    name: 'Universal File Converter', count: '30+ formats',
    action: 'Open File Converter',
    description: 'Convert files between dozens of formats directly inside your browser. Supports documents, spreadsheets, images, and structured data formats.',
  },
  {
    href: '/pdf-tools/', categorySlug: 'pdf-tools',
    name: 'PDF, Split & Merge Tools', count: String(getToolCount('pdf-tools')),
    action: 'Open PDF, Split & Merge Tools',
    description: 'Merge multiple PDF, Excel, Image, or Text documents, split ranges, extract pages, and compile files offline securely.',
  },
  {
    href: '/image-tools/', categorySlug: 'image-tools',
    name: 'Image Tools', count: String(getToolCount('image-tools')),
    description: 'Convert PNG, JPG, WebP, SVG, and BMP formats instantly. Compress, resize, and optimize file sizes client-side in seconds.',
  },
  {
    href: '/document-tools/', categorySlug: 'document-tools',
    name: 'Document Tools', count: String(getToolCount('document-tools')),
    description: 'Process text files, compile document PDFs, convert formatting, and combine rich logs securely inside your local browser tab.',
  },
  {
    href: '/excel-converter/', categorySlug: 'excel-converter',
    name: 'Excel Converter', count: String(getToolCount('excel-converter')),
    description: 'Inspect CSV and Excel sheets client-side. Convert CSV to JSON, JSON to Excel, XLSX to CSV, or compile reports to PDF offline.',
  },
  {
    href: '/business-tools/', categorySlug: 'business-tools',
    name: 'Business Tools', count: String(getToolCount('business-tools')),
    description: 'Create invoices, calculate taxes, and compile print-ready PDFs. Offline-first workflow.',
  },
  {
    href: '/developer-tools/', categorySlug: 'developer-tools',
    name: 'Developer Tools', count: String(getToolCount('developer-tools')),
    description: 'Format JSON, minify code, encode base64, and validate data structures locally.',
  },
];

const popularSlugs = ['pdf-to-word', 'excel-to-pdf', 'image-resizer', 'merge-pdf', 'jpg-to-png', 'image-to-text', 'word-to-pdf', 'split-pdf'];
const popularTools = popularSlugs
  .map(s => tools.find(t => t.slug === s))
  .filter((t): t is (typeof tools)[number] => Boolean(t));

// Nicer chip labels for format tokens (honest — only real formats).
const fmtLabels: Record<string, string> = {
  jpg: 'JPG', jpeg: 'JPG', png: 'PNG', webp: 'WEBP', svg: 'SVG', gif: 'GIF',
  pdf: 'PDF', word: 'DOCX', docx: 'DOCX', ppt: 'PPT', pptx: 'PPTX',
  excel: 'XLSX', xls: 'XLS', xlsx: 'XLSX', csv: 'CSV', json: 'JSON', xml: 'XML',
  txt: 'TXT', image: 'IMG', text: 'TEXT',
};
const chipLabel = (tok: string) => fmtLabels[tok] || tok.toUpperCase();

// Derive scannable chips from a tool slug: a format pair (A → B), or a single action/format chip.
type ToolChips = { pair: true; from: string; to: string } | { pair: false; single: string };
const toolChips = (slug: string): ToolChips => {
  const m = slug.match(/^(.+)-to-(.+)$/);
  if (m) return { pair: true, from: chipLabel(m[1]), to: chipLabel(m[2]) };
  if (slug.startsWith('merge-')) return { pair: false, single: 'MERGE' };
  if (slug.startsWith('split-')) return { pair: false, single: 'SPLIT' };
  if (slug.endsWith('-calculator')) return { pair: false, single: 'CALC' };
  if (slug.endsWith('-generator')) return { pair: false, single: 'PDF' };
  if (slug === 'image-resizer') return { pair: false, single: 'RESIZE' };
  if (slug === 'word-counter') return { pair: false, single: 'COUNT' };
  if (slug === 'json-formatter') return { pair: false, single: 'JSON' };
  return { pair: false, single: chipLabel(slug.split('-')[0]) };
};

---

<Layout title={title} description={description} lang={lang} faqList={faqList}>
  <style>
    /* Homepage Specific CSS */
    .hero-container {
      max-width: 1180px;
      margin: 0 auto;
      padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-2xl);
      text-align: center;
      position: relative;
      z-index: 1;
    }

    /* Phones: tighten the lead-in so the dropzone — the thing that proves
       the headline — is on screen without scrolling. */
    @media (max-width: 940px) {
      .hero-container {
        padding-top: var(--spacing-xl);
        padding-bottom: var(--spacing-xl);
      }
      .hero-subtitle {
        margin-bottom: var(--spacing-xs);
        max-width: 34ch;
      }
    }

    .hero-title {
      font-size: var(--fs-display);
      font-weight: 600;
      line-height: var(--lh-display);
      letter-spacing: var(--ls-display);
      margin-bottom: var(--spacing-md);
      color: var(--colors-ink);
    }

    /* Solid, not gradient-animated. The shimmer competed with the wave
       motion at the base of the hero, and its teal stops fell to 1.60:1
       against the light canvas — unreadable. One colour, one meaning. */
    .hero-title-accent {
      color: var(--colors-accent-display);
    }

    .hero-subtitle {
      font-size: var(--fs-lead);
      color: var(--colors-body);
      max-width: 680px;
      margin: 0 auto var(--spacing-lg);
      line-height: var(--lh-body);
    }

    .hero-cta-group {
      display: flex;
      justify-content: center;
      gap: var(--spacing-md);
      margin-bottom: var(--spacing-2xl);
    }

    /* Hide /⌘K kbd hint on touch devices — no keyboard shortcut */
    @media (max-width: 640px) {
      .search-kbd {
        display: none;
      }
    }

  </style>
  <style is:global>
    /* Premium Autocomplete Search Bar */
    .search-container {
      position: relative;
      max-width: 600px;
      width: 100%;
      margin: var(--spacing-xl) auto;
      z-index: 10;
    }

    .search-input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      border-radius: var(--rounded-lg);
      background-color: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(8px);
      border: 1px solid var(--colors-hairline);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .search-input-wrapper:focus-within {
      border-color: rgba(0, 112, 243, 0.45);
      box-shadow: 0 0 0 3px rgba(0, 112, 243, 0.12), 0 10px 40px rgba(0, 0, 0, 0.06);
      transform: translateY(-1px);
    }

    [data-theme="dark"] .search-input-wrapper {
      background-color: rgba(18, 18, 18, 0.8);
      backdrop-filter: blur(8px);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
    }

    [data-theme="dark"] .search-input-wrapper:focus-within {
      border-color: rgba(0, 223, 216, 0.45);
      box-shadow: 0 0 0 3px rgba(0, 223, 216, 0.18), 0 10px 40px rgba(0, 0, 0, 0.35);
    }

    .search-icon {
      position: absolute;
      left: var(--spacing-md);
      color: var(--colors-mute);
      pointer-events: none;
      display: flex;
      align-items: center;
      transition: color 0.2s ease;
    }

    .search-input-wrapper:focus-within .search-icon {
      color: var(--colors-link);
    }

    .search-input {
      width: 100%;
      padding: 16px var(--spacing-md) 16px 48px;
      font-size: var(--fs-lead);
      border: none;
      background: transparent;
      color: var(--colors-ink);
      outline: none;
      box-shadow: none !important;
    }

    .search-kbd {
      position: absolute;
      right: var(--spacing-md);
      background: var(--colors-canvas-soft-2);
      border: 1px solid var(--colors-hairline);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: var(--fs-micro);
      font-family: inherit;
      color: var(--colors-mute);
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .search-input-wrapper:focus-within .search-kbd {
      opacity: 0;
    }

    [data-theme="dark"] .search-kbd {
      background: rgba(255, 255, 255, 0.05);
    }

    /* Results Dropdown */
    .search-results-panel {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background-color: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(12px);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      max-height: 380px;
      overflow-y: auto;
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.08);
      display: none;
      flex-direction: column;
      z-index: 999;
      padding: var(--spacing-xs) 0;
      animation: dropdown-fade-in 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-theme="dark"] .search-results-panel {
      background-color: rgba(18, 18, 18, 0.95);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.4);
    }

    .search-result-item {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding: var(--spacing-sm) var(--spacing-md);
      text-decoration: none;
      color: var(--colors-ink);
      transition: all 0.2s ease;
      margin: 2px var(--spacing-xs);
      border-radius: var(--rounded-sm);
    }

    .search-result-item:hover, .search-result-item.selected {
      background-color: var(--colors-canvas-soft-2);
      transform: translateX(4px);
    }

    [data-theme="dark"] .search-result-item:hover, [data-theme="dark"] .search-result-item.selected {
      background-color: rgba(255, 255, 255, 0.05);
    }

    .search-result-icon {
      font-size: 20px;
      width: 38px;
      height: 38px;
      border-radius: 8px;
      background-color: var(--colors-canvas-soft-2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--colors-hairline);
    }

    [data-theme="dark"] .search-result-icon {
      background-color: rgba(255, 255, 255, 0.03);
    }

    .search-result-info {
      display: flex;
      flex-direction: column;
      text-align: left;
    }

    .search-result-name {
      font-size: var(--fs-body);
      font-weight: 600;
      color: var(--colors-ink);
    }

    .search-result-desc {
      font-size: var(--fs-micro);
      color: var(--colors-mute);
      margin-top: 1px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 440px;
    }
  </style>
  <style>

    .section-divider {
      max-width: 1200px;
      margin: 0 auto var(--spacing-3xl);
      border: 0;
      height: 1px;
      background-color: var(--colors-hairline);
    }

    /* ── Section primitives ───────────────────────────────────────
       Shared by every band below the fold. Previously these lived as
       inline style attributes repeated per section, which is why the
       page had drifted to 22 different font sizes. */
    .section-title {
      font-size: var(--fs-title);
      font-weight: 600;
      letter-spacing: var(--ls-title);
      line-height: var(--lh-title);
      text-align: center;
      margin-bottom: var(--spacing-xl);
      color: var(--colors-ink);
    }

    .section-title-sm {
      font-size: var(--fs-heading);
      font-weight: 600;
      letter-spacing: var(--ls-heading);
      line-height: var(--lh-heading);
      text-align: center;
      margin-top: var(--spacing-xl);
      color: var(--colors-ink);
    }

    .section-lede {
      text-align: center;
      color: var(--colors-body);
      font-size: var(--fs-body);
      line-height: var(--lh-body);
      max-width: 600px;
      margin: 0 auto var(--spacing-xl);
    }

    /* A band separated from the previous one by a hairline rule. */
    .section-ruled {
      margin-top: var(--spacing-4xl);
      border-top: 1px solid var(--colors-hairline);
      padding-top: var(--spacing-3xl);
    }

    .links-title {
      font-size: var(--fs-subhead);
      font-weight: 600;
      letter-spacing: var(--ls-subhead);
      text-align: center;
      margin-bottom: var(--spacing-lg);
      color: var(--colors-ink);
    }

    /* Long-form copy block: owns its own heading + list rhythm. */
    .prose {
      max-width: 800px;
      margin: 0 auto;
      color: var(--colors-body);
      font-size: var(--fs-body);
      line-height: 1.7;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-lg);
    }
    .prose h3 {
      font-size: var(--fs-subhead);
      font-weight: 600;
      letter-spacing: var(--ls-subhead);
      color: var(--colors-ink);
      margin-top: var(--spacing-md);
    }
    .prose ul {
      padding-left: var(--spacing-lg);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    /* Bento layout for the category grid. A uniform 2-column grid gave all
       seven categories equal weight, which is false — the universal converter
       covers 30+ formats and the PDF set is the most-used. Tile size encodes
       that, so the structure carries information instead of decorating. */
    .tool-grid--bento {
      grid-template-columns: repeat(6, 1fr);
      gap: var(--spacing-md);
    }
    .tool-grid--bento > :nth-child(1) { grid-column: span 4; }
    .tool-grid--bento > :nth-child(2) { grid-column: span 2; }
    .tool-grid--bento > :nth-child(3),
    .tool-grid--bento > :nth-child(4),
    .tool-grid--bento > :nth-child(5) { grid-column: span 2; }
    .tool-grid--bento > :nth-child(6),
    .tool-grid--bento > :nth-child(7) { grid-column: span 3; }

    /* The lead tile carries the largest category, so it gets the larger type. */
    .tool-grid--bento > :nth-child(1) .tool-name { font-size: var(--fs-heading); }

    @media (max-width: 900px) {
      .tool-grid--bento { grid-template-columns: repeat(2, 1fr); }
      .tool-grid--bento > :nth-child(1) { grid-column: span 2; }
      .tool-grid--bento > :nth-child(n+2) { grid-column: span 1; }
    }
    @media (max-width: 600px) {
      .tool-grid--bento { grid-template-columns: 1fr; }
      .tool-grid--bento > * { grid-column: span 1 !important; }
    }

    /* Guides on phones: 13 cards at 291px each made this the tallest band
       on the page (4,446px). Clamp the description and tighten the padding
       rather than dropping cards - every guide link stays in the document. */
    @media (max-width: 600px) {
      .featured-card {
        padding: var(--spacing-md);
        gap: var(--spacing-xs);
      }
      .featured-card-desc {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    }

    /* The single accent every tool and category tile draws from. */
    .popular-card,
    .explore-card {
      --accent: var(--colors-accent-display);
    }

    @media (max-width: 600px) {
      /* At 165px wide the description truncates to "Convert legacy E…",
         which carries no meaning the chips and name do not already give. */
      .explore-card-desc { display: none; }
    }

    .section-actions {
      text-align: center;
      margin-top: var(--spacing-xl);
    }

    .featured-badge--time {
      color: var(--colors-link);
      font-weight: 600;
    }

    .links-grid--centered {
      grid-template-columns: repeat(4, 1fr);
      justify-items: center;
      text-align: center;
    }
    @media (max-width: 560px) {
      .links-grid--centered {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* Popular Searches Styling */
    .popular-searches {
      margin-top: var(--spacing-md);
      font-size: var(--fs-small);
      color: var(--colors-body);
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
    }
    .popular-searches-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: var(--fs-micro);
      color: var(--colors-mute);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-right: 4px;
    }
    .popular-search-link {
      color: var(--colors-link);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }
    .popular-search-link:hover {
      color: var(--colors-link-deep);
      text-decoration: underline;
    }
    .popular-search-separator {
      color: var(--colors-hairline-strong);
      user-select: none;
      margin: 0 2px;
    }

    /* Featured Tools Styling */
    .featured-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-4xl);
      padding: 0 var(--spacing-lg);
    }
    .featured-title {
      font-size: var(--fs-title);
      font-weight: 600;
      letter-spacing: -1.2px;
      margin-bottom: var(--spacing-xl);
      color: var(--colors-ink);
      text-align: center;
    }
    .featured-grid {
      display: grid;
      /* auto-fit reflows 3 → 2 → 1 without breakpoints */
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--spacing-lg);
    }
    .featured-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      position: relative;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.02), inset 0px 0px 0px 1px var(--colors-hairline);
    }
    .featured-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.05), inset 0px 0px 0px 1px var(--colors-hairline-strong);
    }
    .featured-badge {
      align-self: flex-start;
      font-size: var(--fs-micro);
      font-weight: 500;
      padding: 2px 8px;
      border-radius: var(--rounded-pill);
      background-color: var(--colors-canvas-soft-2);
      color: var(--colors-body);
      font-family: 'JetBrains Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.2px;
    }
    [data-theme="dark"] .featured-badge {
      background-color: rgba(255, 255, 255, 0.05);
    }
    .featured-card-header {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
    }
    .featured-card-icon {
      font-size: var(--fs-heading);
      width: 44px;
      height: 44px;
      background-color: var(--colors-canvas-soft-2);
      border-radius: var(--rounded-md);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--colors-hairline);
    }
    [data-theme="dark"] .featured-card-icon {
      background-color: rgba(255, 255, 255, 0.03);
    }
    .featured-card-name {
      font-size: var(--fs-subhead);
      font-weight: 600;
      letter-spacing: -0.4px;
      color: var(--colors-ink);
      margin: 0;
    }
    .featured-card-desc {
      font-size: var(--fs-small);
      color: var(--colors-body);
      line-height: 1.5;
      flex-grow: 1;
      margin: 0;
    }
    .featured-cta {
      align-self: flex-start;
      margin-top: var(--spacing-xs);
    }

    /* Comparison Table Styling */
    .comparison-section {
      max-width: 1200px;
      margin: 0 auto var(--spacing-4xl);
      padding: 0 var(--spacing-lg);
      text-align: center;
    }
    .comparison-title {
      font-size: var(--fs-title);
      font-weight: 600;
