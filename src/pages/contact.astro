---
import Layout from '../layouts/Layout.astro';

const { lang = 'en' } = Astro.props;

const title = "Contact Us | ConvertOcean secure utilities";
const description = "Get in touch with the ConvertOcean support and development team. Submit feedback, report bugs, or make corporate partnership inquiries.";
---

<Layout title={title} description={description} lang={lang} category="Contact Us" categorySlug="contact">
  <style>
    .contact-container {
      max-width: 800px;
      margin: 0 auto;
    }
    .contact-lead {
      font-size: 20px;
      color: var(--colors-body);
      line-height: 1.6;
      margin-bottom: var(--spacing-xl);
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--spacing-2xl);
      margin-top: var(--spacing-lg);
    }
    @media (max-width: 768px) {
      .contact-grid {
        grid-template-columns: 1fr;
        gap: var(--spacing-xl);
      }
    }
    .contact-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-xl);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.01);
    }
    .contact-info-section {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-lg);
    }
    .info-block {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xxs);
    }
    .info-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--colors-mute);
      letter-spacing: 0.5px;
    }
    .info-value {
      font-size: 15px;
      color: var(--colors-ink);
      font-weight: 500;
      text-decoration: none;
    }
    .info-desc {
      font-size: 13px;
      color: var(--colors-body);
      line-height: 1.5;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: var(--spacing-md);
    }
    .form-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--colors-body);
    }
    .text-area {
      min-height: 120px;
      resize: vertical;
      font-family: inherit;
      padding: var(--spacing-sm);
    }
    .contact-privacy-note {
      font-size: 12.5px;
      color: var(--colors-mute);
      line-height: 1.5;
      margin-top: var(--spacing-md);
      display: flex;
      align-items: flex-start;
      gap: 6px;
    }
    .submit-success {
      background-color: var(--colors-link-bg-soft);
      border: 1px solid var(--colors-link);
      color: var(--colors-link-deep);
      border-radius: var(--rounded-sm);
      padding: var(--spacing-md);
      font-size: 14px;
      font-weight: 500;
      display: none;
      align-items: center;
      gap: var(--spacing-xs);
      margin-bottom: var(--spacing-md);
    }
  </style>

  <main class="app-container" style="max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); position: relative; z-index: 1;">
    <div class="contact-container">
      <div class="page-header">
        <h1 class="page-title">Contact Us.</h1>
        <p class="contact-lead">Have questions, bugs to report, or ideas for new client-side tools? Reach out directly and let us know how we can make ConvertOcean better.</p>
      </div>

      <div class="contact-grid">
        <!-- Contact Form Card -->
        <div class="contact-card">
          <div id="submitSuccess" class="submit-success">
            <span>✅</span>
            <span>Thank you for your message! Since we run entirely client-side, your email client will open to send this message securely.</span>
          </div>

          <form id="contactForm" onsubmit="event.preventDefault(); handleContactSubmit();">
            <div class="form-group">
              <label for="contactName" class="form-label">Name</label>
              <input type="text" id="contactName" class="form-input" placeholder="Your name" required />
            </div>

            <div class="form-group">
              <label for="contactEmail" class="form-label">Email Address</label>
              <input type="email" id="contactEmail" class="form-input" placeholder="you@example.com" required />
            </div>

            <div class="form-group">
              <label for="contactReason" class="form-label">Reason for Inquiry</label>
              <select id="contactReason" class="select-input" required>
                <option value="General Support">General Support / FAQ Inquiry</option>
                <option value="Bug Report">Bug Report / Tool Malfunction</option>
                <option value="Feature Request">Feature Request / New Tool Idea</option>
                <option value="Partnership">Partnership / Corporate Integration</option>
                <option value="Security">Security Disclosures</option>
              </select>
            </div>

            <div class="form-group">
              <label for="contactMessage" class="form-label">Message</label>
              <textarea id="contactMessage" class="form-input text-area" placeholder="Write your message here..." required></textarea>
            </div>

            <button type="submit" class="button button-primary" style="width: 100%; margin-top: var(--spacing-sm);">Send Message</button>
          </form>

          <p class="contact-privacy-note">
            <span>🔒</span>
            <span><strong>Privacy Note:</strong> We do not store form data in any cloud databases. Sending this form opens a local secure mail link to forward your message directly from your browser.</span>
          </p>
        </div>

        <!-- Contact Information Sidebar -->
        <div class="contact-info-section">
          <div class="info-block">
            <span class="info-label">Developer Support</span>
            <a href="mailto:support@convertocean.com" class="info-value">support@convertocean.com</a>
            <p class="info-desc">Reach out for help with file conversions, feature guides, or generic support.</p>
          </div>

          <div class="info-block">
            <span class="info-label">Partnerships</span>
            <a href="mailto:partners@convertocean.com" class="info-value">partners@convertocean.com</a>
            <p class="info-desc">For white-label inquiries, local offline tools, or browser integration requests.</p>
          </div>

          <div class="info-block">
            <span class="info-label">Security & OCR Reporting</span>
            <a href="mailto:security@convertocean.com" class="info-value">security@convertocean.com</a>
            <p class="info-desc">Report vulnerabilities, data leakage concerns, or private OCR sandbox bugs.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    function handleContactSubmit() {
      const name = document.getElementById('contactName').value;
      const email = document.getElementById('contactEmail').value;
      const reason = document.getElementById('contactReason').value;
      const message = document.getElementById('contactMessage').value;

      const subject = encodeURIComponent(`ConvertOcean [${reason}] - From ${name}`);
      const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\nInquiry: ${reason}\n\nMessage:\n${message}`);
      
      const mailtoUrl = `mailto:support@convertocean.com?subject=${subject}&body=${body}`;
      
      document.getElementById('submitSuccess').style.display = 'flex';
      document.getElementById('contactForm').reset();
      
      // Open mailto link
      window.location.href = mailtoUrl;
    }
  </script>
</Layout>
