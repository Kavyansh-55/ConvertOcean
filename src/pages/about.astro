---
import Layout from '../layouts/Layout.astro';

const { lang = 'en' } = Astro.props;

const title = "About ConvertOcean | Browser-Based Secure File Utility Platform";
const description = "Discover the technology and mission behind ConvertOcean: a client-side, offline-first file conversion toolset prioritizing user privacy and absolute data safety.";

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About ConvertOcean",
  "url": "https://convertocean.com/about/",
  "mainEntity": {
    "@type": "Organization",
    "name": "ConvertOcean",
    "url": "https://convertocean.com",
    "logo": "https://convertocean.com/favicon.svg",
    "foundingDate": "2026",
    "description": "An independent, privacy-first suite of client-side file converters, PDF utilities, and business calculators that run entirely in the browser with no server uploads."
  }
};
---

<Layout title={title} description={description} lang={lang} category="About Us" categorySlug="about">
  <style>
    .about-container {
      max-width: 800px;
      margin: 0 auto;
    }
    .about-lead {
      font-size: 20px;
      color: var(--colors-body);
      line-height: 1.6;
      margin-bottom: var(--spacing-xl);
    }
    .about-section {
      margin-bottom: var(--spacing-2xl);
    }
    .about-section-title {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.6px;
      margin-bottom: var(--spacing-sm);
      color: var(--colors-ink);
    }
    .about-text {
      font-size: 15.5px;
      color: var(--colors-body);
      line-height: 1.7;
      margin-bottom: var(--spacing-md);
    }
    .values-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-lg);
      margin: var(--spacing-xl) 0;
    }
    @media (max-width: 600px) {
      .values-grid {
        grid-template-columns: 1fr;
      }
    }
    .value-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      padding: var(--spacing-lg);
      transition: transform 0.2s, border-color 0.2s;
    }
    .value-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
    }
    .value-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-bottom: var(--spacing-xs);
      display: flex;
      align-items: center;
      gap: var(--spacing-xxs);
    }
    .value-text {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.6;
    }
    .tech-badge-container {
      display: flex;
      flex-wrap: wrap;
      gap: var(--spacing-xs);
      margin: var(--spacing-md) 0;
    }
    .tech-badge {
      background-color: var(--colors-canvas-soft-2);
      border: 1px solid var(--colors-hairline);
      padding: 6px 12px;
      border-radius: var(--rounded-sm);
      font-size: 12.5px;
      font-family: 'JetBrains Mono', monospace;
      color: var(--colors-body);
    }
  </style>

  <main class="app-container" style="max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); position: relative; z-index: 1;">
    <div class="about-container">
      <div class="page-header">
        <h1 class="page-title">About ConvertOcean.</h1>
        <p class="about-lead">We are building the next generation of web utility tools—powered entirely by your local browser sandbox, keeping your documents and images completely secure.</p>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">Our Mission</h2>
        <p class="about-text">
          Most online tools operate by forcing users to upload their documents, spreadsheets, and private photos to remote cloud servers. This exposes sensitive company databases, client reports, billing addresses, and personal identities to data breaches, advertising trackers, and model-training indexing.
        </p>
        <p class="about-text">
          ConvertOcean was founded to prove that web utility programs can be both powerful and private. By leveraging modern client-side capabilities, we run all file conversion, compilation, and formatting operations locally on your hardware. Your files never leave your computer.
        </p>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">Core Principles</h2>
        <div class="values-grid">
          <div class="value-card">
            <h3 class="value-title">🔒 Privacy First</h3>
            <p class="value-text">
              We guarantee device-level data sovereignty. Zero tracking, zero telemetry, zero cookies, and zero server storage.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">⚡ High Performance</h3>
            <p class="value-text">
              By running files locally, we bypass network upload bottlenecks. Conversions start instantly, even for large formats.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">🔌 Offline Capability</h3>
            <p class="value-text">
              Once loaded in your browser, ConvertOcean runs without an internet connection. Seamless tool usage anywhere.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">🆓 Open & Free</h3>
            <p class="value-text">
              No subscription walls, conversion caps, or mandatory email signups. High-fidelity tools accessible to everyone.
            </p>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">Our Technology Stack</h2>
        <p class="about-text">
          To achieve secure client-side execution, we rely on a compilation of state-of-the-art web browser technologies:
        </p>
        <div class="tech-badge-container">
          <span class="tech-badge">Astro Framework</span>
          <span class="tech-badge">WebAssembly (WASM)</span>
          <span class="tech-badge">SheetJS (XLSX/CSV)</span>
          <span class="tech-badge">pdf.js / pdf-lib</span>
          <span class="tech-badge">Tesseract.js OCR</span>
          <span class="tech-badge">HTML5 File API</span>
        </div>
        <p class="about-text" style="margin-top: var(--spacing-sm);">
          These compiled libraries are cached inside your browser sandbox tab memory. When you choose a tool, the browser runs the library dynamically using your local CPU, producing high-fidelity outputs in seconds.
        </p>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">Who Builds ConvertOcean</h2>
        <p class="about-text">
          ConvertOcean is an independent project — designed, developed, and maintained by a small indie team rather than a large corporation. That independence is deliberate: because we do not answer to advertisers or data brokers, we have no incentive to collect your files, track your behavior, or lock features behind subscriptions. Every tool on this site exists because we needed it ourselves and wanted a version that respected the user.
        </p>
        <p class="about-text">
          The same people who write the conversion engines also answer support questions. If you find a bug, spot an incorrect result, or want a new tool, you can reach us directly through the <a href="/contact/" style="color: var(--colors-link);">contact page</a> — reports go straight to the developers who can fix them.
        </p>
      </div>

      <div class="about-section">
        <h2 class="about-section-title">How We Test and Verify Our Tools</h2>
        <p class="about-text">
          Accuracy matters as much as privacy. Before a converter or calculator ships, it goes through a consistent verification process:
        </p>
        <div class="values-grid">
          <div class="value-card">
            <h3 class="value-title">🧮 Standard formulas only</h3>
            <p class="value-text">
              Our business calculators — like the <a href="/profit-margin-calculator/" style="color: var(--colors-link);">Profit Margin Calculator</a> and <a href="/sales-tax-calculator/" style="color: var(--colors-link);">Sales Tax Calculator</a> — use the standard accounting and mathematical definitions, and each tool page shows its exact formulas so you can verify every result by hand.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">✅ Reference-checked outputs</h3>
            <p class="value-text">
              File converters are tested against reference files: we convert known documents, spreadsheets, and images and compare the output against expected results before and after every significant update.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">📚 Proven open-source engines</h3>
            <p class="value-text">
              We build on widely audited open-source libraries (pdf.js, pdf-lib, SheetJS, Tesseract) used by thousands of production applications, rather than unproven custom parsers.
            </p>
          </div>
          <div class="value-card">
            <h3 class="value-title">🔍 Dated reviews & corrections</h3>
            <p class="value-text">
              Calculator pages carry a last-reviewed note, and tax-rate presets are periodically checked. If a user reports an inaccuracy, verifying and correcting it takes priority over shipping anything new.
            </p>
          </div>
        </div>
        <p class="about-text">
          One honest caveat: our calculators are informational tools, not professional advice. They are built to be mathematically correct, but decisions about pricing, taxes, or filings should always be confirmed with a qualified accountant or your local tax authority.
        </p>
      </div>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)}></script>
</Layout>
