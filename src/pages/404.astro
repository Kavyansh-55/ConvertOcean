---
import Layout from '../layouts/Layout.astro';

const { lang = 'en' } = Astro.props;

const title = "404 - Page Not Found | ConvertOcean";
const description = "The page you are looking for does not exist or has been moved on ConvertOcean.";
---

<Layout title={title} description={description} lang={lang} category="404 - Page Not Found" categorySlug="404">
  <main class="app-container" style="max-width: 800px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; position: relative; z-index: 1;">
    <div style="font-size: 80px; margin-bottom: var(--spacing-md); filter: drop-shadow(0 0 15px rgba(0,0,0,0.05)); font-weight: 700; letter-spacing: -2px; color: var(--colors-ink);">404</div>
    <h1 class="page-title" style="font-size: 32px; font-weight: 600; margin-bottom: var(--spacing-sm); color: var(--colors-ink); letter-spacing: -1px;">Lost at sea.</h1>
    <p style="font-size: 16px; color: var(--colors-body); max-width: 480px; margin-bottom: var(--spacing-xl); line-height: 1.6;">
      The page you are looking for doesn't exist, has been removed, or has moved to a new destination on ConvertOcean.
    </p>
    <div style="display: flex; gap: var(--spacing-md); justify-content: center; flex-wrap: wrap;">
      <a href="/" class="button button-primary" style="display: inline-flex; align-items: center; gap: 8px;">
        Go to Homepage
      </a>
      <a href="/file-converter/" class="button button-secondary" style="display: inline-flex; align-items: center; gap: 8px;">
        Browse Converters
      </a>
    </div>
  </main>
</Layout>
