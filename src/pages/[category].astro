---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
import CategoryIcon from '../components/CategoryIcon.astro';

export function getStaticPaths() {
  const categories = ['pdf-tools', 'image-tools', 'document-tools', 'excel-converter', 'ocr-tools', 'business-tools', 'developer-tools'];
  return categories.map(category => ({ params: { category } }));
}

const { category } = Astro.params;
const { lang = 'en' } = Astro.props;

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

if (category === 'ocr-tools') {
  return Astro.redirect(relLink('/image-tools/'), 301);
}

const categoriesMap: Record<string, { name: string; description: string; icon: string; seoTitle: string; seoDescription: string }> = {
  'pdf-tools': {
    name: 'PDF, Split & Merge Tools',
    description: 'Merge multiple PDF, Excel, Image, or Text documents, split ranges, extract pages, and compile documents offline securely.',
    icon: '🥞',
    seoTitle: 'Secure Offline PDF, Split & Merge Tools - Merge & Split Files Locally | ConvertOcean',
    seoDescription: 'Stitch multiple PDF, Excel, image, or text documents together or extract specific pages/ranges securely inside browser memory. 100% private, free, no uploads.'
  },
  'image-tools': {
    name: 'Image Tools',
    description: 'Convert between PNG, JPG, WebP formats, resize and compress images client-side instantly.',
    icon: '🖼️',
    seoTitle: 'Local Image Converter - Convert PNG, JPG, WebP Online | ConvertOcean',
    seoDescription: 'Compress and convert image formats locally on your device. WebP, PNG, JPG, and WebP compression running client-side. No server uploads, 100% private.'
  },
  'document-tools': {
    name: 'Document Tools',
    description: 'Process raw text files, compile document PDFs, and extract contents client-side.',
    icon: '📝',
    seoTitle: 'Secure Document Tools & Text Converters Offline | ConvertOcean',
    seoDescription: 'Securely process documents client-side. Convert text to PDF, extract PDF text, combine text files, and manage documents 100% locally with zero server uploads.'
  },
  'excel-converter': {
    name: 'Excel Converter',
    description: 'Inspect, convert, and format Excel workbooks and CSV sheets offline. Convert Excel to PDF, CSV to JSON, JSON to CSV, XLSX to CSV, or CSV to XLSX offline.',
    icon: '📊',
    seoTitle: 'Excel Converter - Private CSV & XLSX Spreadsheet Tools | ConvertOcean',
    seoDescription: 'Convert Excel spreadsheets and CSV sheets to print-ready PDF, JSON, and XLSX client-side. Keep financial data private, secure, and offline.'
  },
  'ocr-tools': {
    name: 'OCR Tools',
    description: 'Private Image-to-Text OCR engine. Extract text from scans, screenshots, receipts, and images locally.',
    icon: '🔍',
    seoTitle: 'Image to Text OCR - Extract Text from Scans Offline | ConvertOcean',
    seoDescription: 'Extract plain text from screenshots, documents, and scans locally in your browser window. Private client-side OCR tool with 100% data confidentiality.'
  },
  'business-tools': {
    name: 'Business Tools',
    description: 'Generate invoices, create receipts, calculate profit margins, compute percentages, and estimate sales tax \u2014 all 100% client-side.',
    icon: '💼',
    seoTitle: 'Private Business Tools - Invoice, Receipt, Tax & Margin Calculator | ConvertOcean',
    seoDescription: 'Generate invoices, create receipts, calculate profit margins, compute percentages, and estimate sales tax privately in your browser. No server uploads. 100% free.'
  },
  'developer-tools': {
    name: 'Developer Tools',
    description: 'Format JSON, convert XML, parse CSV, and compile developer datasets offline client-side.',
    icon: '⚙️',
    seoTitle: 'Private Offline Developer Tools & Utilities | ConvertOcean',
    seoDescription: 'Convert CSV to JSON, JSON to CSV, XML to JSON locally. 100% private developer utilities with zero server uploads.'
  }
};

const catInfo = categoriesMap[category] || {
  name: 'File Tools',
  description: 'Privacy-first browser-based file tools.',
  icon: '⚡',
  seoTitle: 'Private Offline Browser Utilities | ConvertOcean',
  seoDescription: 'Secure browser-based file converter utilities. Process everything locally and offline. No server uploads.'
};
let filteredTools = tools.filter(t => t.categorySlug === category);
if (category === 'pdf-tools') {
  filteredTools = tools.filter(t => 
    t.categorySlug === 'pdf-tools' ||
    t.slug.toLowerCase().includes('pdf') || 
    t.name.toLowerCase().includes('pdf') ||
    t.slug.toLowerCase().includes('merge') ||
    t.slug.toLowerCase().includes('split')
  );
}

const title = catInfo.seoTitle;
const description = catInfo.seoDescription;

const categoryFaqsMap: Record<string, { q: string; a: string }[]> = {
  'pdf-tools': [
    {
      q: "Can I merge files of different orientations or formats?",
      a: "Yes, you can combine multiple PDF files, images, or text documents together. Layout dimensions are calculated and formatted to standard A4/Letter size or stitched into landscape viewports."
    },
    {
      q: "Is there a maximum file size or page limit when splitting PDF files?",
      a: "Because all PDF split and merge compilation runs client-side on your device, the file size limit is determined by your system's RAM. Most modern browsers can easily split or merge PDF documents up to several hundred megabytes."
    },
    {
      q: "How does ConvertOcean merge PDF files without losing interactive elements?",
      a: "Our client-side merger consolidates resource libraries (like fonts, page coordinates, and form structures) to prevent file size bloat while keeping links, text flows, and standard annotations intact."
    }
  ],
  'image-tools': [
    {
      q: "What is the best image format for reducing page load speeds?",
      a: "Modern WebP formats are optimal for websites because they offer transparency support and are 25-30% smaller than JPG files. We recommend converting PNG or JPG assets to WebP for production use."
    },
    {
      q: "Does converting a low-resolution JPG to a PNG layout restore image detail?",
      a: "No. While PNG is a lossless format that prevents further compression artifacts in future saves, it cannot restore visual pixels or metadata discarded by the original lossy JPG compression."
    },
    {
      q: "Can I run image format conversions in batch mode offline?",
      a: "Yes. All image rasterization, color channel processing, and metadata updates run locally using HTML5 canvas capabilities in browser sandbox memory, meaning you can convert batches of images offline."
    }
  ],
  'excel-converter': [
    {
      q: "Does this tool evaluate formulas and macros when converting Excel files?",
      a: "Our spreadsheet engine evaluates the calculated cell values in the sheet and renders the text or numbers. Standard formulas are evaluated local-side, but macros (.xlsm) or external database lookups are not supported."
    },
    {
      q: "Which sheet is processed when converting multi-sheet workbooks to CSV?",
      a: "When converting XLSX/XLS workbooks to CSV, only the first visible sheet is parsed and exported. To convert other sheets, you can reorder them to the front of the workbook in Excel before uploading."
    },
    {
      q: "How secure is my financial spreadsheet data on ConvertOcean?",
      a: "Absolutely secure. All cell parsing, formula compilation, and CSV/JSON exports are computed in your browser sandbox memory on your local machine. No corporate records, budgets, or pricing tables leave your hardware."
    }
  ],
  'document-tools': [
    {
      q: "How does the document conversion engine preserve paragraph flows?",
      a: "The engine extracts text layouts, preserves line breaks, wraps paragraphs, and formats them to fit standard margins. It compiles clean text nodes and outputs standard formats locally."
    },
    {
      q: "Can I parse scanned Word documents into TXT files?",
      a: "No. Scanned or image-based DOCX files do not contain selectable text characters. To extract text from these documents, you should convert the pages to images and run them through our Image to Text OCR."
    },
    {
      q: "What options are supported when merging plain text files?",
      a: "You can customize separator delimiters between files (such as single newlines, double newlines, or custom text borders) to merge codebase files, logs, or text outputs in a clean order."
    }
  ],
  'ocr-tools': [
    {
      q: "How does the OCR engine identify characters from poor quality scans?",
      a: "The local OCR engine uses image pre-processing algorithms (binarization, deskewing, and noise removal) to convert images into high-contrast monochrome pixels. It then applies feature detection to match shapes with character models."
    },
    {
      q: "What languages are supported by the client-side text extractor?",
      a: "Our WebAssembly OCR engine is pre-configured to extract English characters. It accurately processes screenshot text, code structures, receipt rows, and scanned PDF forms."
    },
    {
      q: "Are my screenshots and scanned text private?",
      a: "Yes. All optical character recognition is performed locally on your device's CPU/GPU via WebAssembly (Tesseract.js). No graphic assets, extracted text, or client data are sent over the network."
    }
  ],
  'business-tools': [
    {
      q: "Can I customize tax settings for invoice and receipt generation?",
      a: "Yes. You can select standard preset rates (like GST 18%, VAT 15%) or type any custom tax rate percentage. Taxes are automatically calculated and detailed on the downloadable A4 PDF."
    },
    {
      q: "What is the difference between profit margin and markup?",
      a: "Profit margin represents the percentage of selling price that is profit, while markup is the percentage added to the wholesale cost to set the selling price. Margin can never exceed 100%, but markup can be infinite."
    },
    {
      q: "Does the sales tax calculator support reverse tax back-calculation?",
      a: "Yes. You can calculate the net pre-tax price and exact tax amount from a tax-inclusive gross total by selecting the reverse tax mode in the calculator interface."
    }
  ],
  'developer-tools': [
    {
      q: "Are my JSON datasets and XML structure schemas safe?",
      a: "Yes. All developer parsing utilities process values client-side on your local device. None of your data entries are logged or uploaded to remote databases or server instances."
    },
    {
      q: "Can I convert large database CSV payloads locally?",
      a: "Absolutely. Local parsing speeds are determined entirely by your device CPU performance and memory. Large CSV files are parsed instantly directly in your browser tab memory sandbox."
    }
  ]
};

const faqList = categoryFaqsMap[category] || [];

// Unique per-category intro prose (rendered between the tool grid and FAQs)
const categoryIntroMap: Record<string, string> = {
  'pdf-tools': `
    <h2>A Complete PDF Toolkit That Never Uploads Your Documents.</h2>
    <p>PDF work usually means juggling several small jobs around one document: combining scanned pages with <a href="/merge-pdf/">Merge PDF</a>, pulling a signature page out with <a href="/split-pdf/">Split PDF</a>, making a contract editable again via <a href="/pdf-to-word/">PDF to Word</a>, or extracting raw text with <a href="/pdf-to-txt/">PDF to TXT</a>. The catch is that PDFs are usually the documents you least want on someone else's server — contracts, statements, medical records, IDs. Every tool on this page parses and rebuilds PDF structures inside your browser's memory using client-side engines, so files never cross the network. Start with our guide on <a href="/guides/merge-multiple-pdf-files/">merging multiple PDF files</a> if you are assembling a document bundle.</p>
  `,
  'image-tools': `
    <h2>Convert Between Image Formats Without Uploading a Single Pixel.</h2>
    <p>Each image format earns its place: JPG compresses photographs hard, PNG keeps screenshots and logos pixel-perfect with transparency, and WebP shrinks web assets by a quarter or more. These tools convert between all of them — plus merging, splitting, and turning images into PDFs or editable text with <a href="/image-to-text/">OCR</a> — using your browser's own canvas and WebAssembly engines. Nothing is uploaded, which matters more for images than people think: photos carry location metadata, screenshots carry whatever was on your screen. Not sure which format a job needs? The <a href="/guides/png-vs-jpg/">PNG vs JPG guide</a> explains the trade-offs with examples, including where WebP fits.</p>
  `,
  'excel-converter': `
    <h2>Spreadsheet Conversions That Keep Your Numbers on Your Machine.</h2>
    <p>Spreadsheets are where businesses keep their most sensitive numbers — payroll, pricing, customer lists — which makes "upload your file to convert it" a bad deal. This suite converts Excel workbooks between XLSX, XLS, CSV, JSON, and XML in both directions, exports print-ready PDFs with <a href="/excel-to-pdf/">Excel to PDF</a>, and merges or splits workbooks, all inside your browser using a client-side spreadsheet engine. Formulas are evaluated locally and only their calculated values are exported, so your pricing logic stays private. Wide sheets getting cut off in PDF exports? Our guide on <a href="/guides/excel-to-pdf/">converting Excel to PDF without losing columns</a> covers the fixes.</p>
  `,
  'document-tools': `
    <h2>Document Conversions for Word, Text, and Presentations — All Local.</h2>
    <p>Documents move between formats constantly: a Word file becomes a fixed PDF for sending with <a href="/word-to-pdf/">Word to PDF</a>, a received PDF becomes editable again with <a href="/pdf-to-word/">PDF to Word</a>, presentations flatten to PDF, and notes need bundling or splitting. These converters parse DOCX, TXT, and PPTX structures directly in your browser — nothing is uploaded, which is exactly what unpublished manuscripts, contracts, and internal decks require. Conversion quality depends on knowing a few format quirks, so if you are moving between PDF and Word, start with the guide on <a href="/guides/pdf-to-word-without-losing-formatting/">converting PDF to Word without losing formatting</a>.</p>
  `,
  'business-tools': `
    <h2>Business Math and Paperwork, Computed Privately.</h2>
    <p>Six tools cover the everyday numbers of running a business: the <a href="/profit-margin-calculator/">Profit Margin Calculator</a> and <a href="/break-even-calculator/">Break-Even Calculator</a> answer pricing and survival-volume questions, the <a href="/sales-tax-calculator/">Sales Tax Calculator</a> and Percentage Calculator handle billing math, and the <a href="/invoice-generator/">Invoice Generator</a> and Receipt Generator produce the A4 PDF paperwork. Every calculator shows its formula next to the result so you can verify the arithmetic, and everything computes client-side — costs, margins, and client details are never uploaded. New to margin math? The step-by-step guide on <a href="/guides/how-to-calculate-profit-margin/">how to calculate profit margin</a> walks through the formulas with worked examples.</p>
  `,
  'developer-tools': `
    <h2>Data Format Utilities That Respect Your Payloads.</h2>
    <p>Developer data is full of things that should never touch a third-party server — API keys in config files, customer records in exports, tokens in webhook payloads. These utilities convert between CSV, JSON, and XML, validate and pretty-print with the <a href="/json-formatter/">JSON Formatter</a>, and analyze text with the <a href="/word-counter/">Word Counter</a>, all using your browser's native parsers. That local-first design also means they work offline and at native speed — a large CSV parses as fast as your machine allows, not as fast as an upload queue. For the mechanics of moving spreadsheet data into application code, see the <a href="/guides/csv-to-json/">CSV to JSON developer guide</a>.</p>
  `
};
const categoryIntro = categoryIntroMap[category];
---

<Layout title={title} description={description} lang={lang} category={catInfo.name} categorySlug={category} faqList={faqList}>
  <style>
    .category-intro {
      max-width: 800px;
      margin: var(--spacing-3xl) auto 0;
      font-size: 14.5px;
      line-height: 1.7;
      color: var(--colors-body);
    }
    .category-intro h2 {
      font-size: 22px;
      font-weight: 600;
      color: var(--colors-ink);
      letter-spacing: -0.88px;
      margin-bottom: var(--spacing-md);
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }
    .category-intro a {
      color: var(--colors-link);
      text-decoration: underline;
      transition: color 0.2s;
    }
    .category-intro a:hover {
      color: var(--colors-link-deep);
    }
  </style>
  <main class="page-container" style="max-width: 1200px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl);">
    <div class="page-header" style="text-align: center; margin-bottom: var(--spacing-3xl);">
      <div class="category-header-icon-wrapper" style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border-radius: var(--rounded-lg); background-color: var(--colors-canvas-soft-2); border: 1px solid var(--colors-hairline); margin-bottom: var(--spacing-md); color: var(--colors-ink); box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.03), inset 0 0 0 1px var(--colors-hairline);">
        <CategoryIcon categorySlug={category} width="40" height="40" />
      </div>
      <h1 class="page-title" style="font-size: 38px; font-weight: 600; letter-spacing: -1.5px; color: var(--colors-ink);">{catInfo.name}</h1>
      <p class="page-description" style="font-size: 16px; color: var(--colors-body); max-width: 600px; margin: var(--spacing-xs) auto 0; line-height: 1.5;">{catInfo.description}</p>
    </div>

    <hr class="section-divider" style="max-width: 100%; margin-bottom: var(--spacing-2xl); border: 0; height: 1px; background-color: var(--colors-hairline);">

    <div class="tool-grid">
      {filteredTools.map(tool => (
        <a href={relLink(`/${tool.slug}/`)} class="tool-card">
          <div class="tool-info">
            <div class="tool-icon-wrapper"><CategoryIcon icon={tool.icon} width="20" height="20" /></div>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-description">{tool.description}</p>
          </div>
          <div class="tool-action-link">
            Open Tool
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty State if no tools found -->
    {filteredTools.length === 0 && (
      <div style="text-align: center; padding: var(--spacing-3xl) 0; color: var(--colors-mute);">
        <div style="font-size: 36px; margin-bottom: var(--spacing-sm);">📭</div>
        <p>No tools are currently active in this category.</p>
        <a href={relLink('/')} class="button button-secondary" style="margin-top: var(--spacing-md); display: inline-flex;">Back to Homepage</a>
      </div>
    )}
    <!-- Category Intro (unique prose per hub) -->
    {categoryIntro && (
      <section class="category-intro" data-reveal set:html={categoryIntro}></section>
    )}

    <!-- FAQ Section -->
    {faqList && faqList.length > 0 && (
      <section class="faq-section" style="margin-top: var(--spacing-3xl);">
        <h2 class="faq-title" style="font-size: 20px; margin-bottom: var(--spacing-lg);">Frequently Asked Questions</h2>
        <div class="faq-container">
          {faqList.map(faq => (
            <div class="faq-item">
              <div class="faq-question">
                {faq.q}
                <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </div>
              <div class="faq-answer">
                {faq.a}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
