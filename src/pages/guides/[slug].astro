---
import Layout from '../../layouts/Layout.astro';
import { guides } from '../../data/guides';
import { tools } from '../../data/tools';
import CategoryIcon from '../../components/CategoryIcon.astro';

export function getStaticPaths() {
  return guides.map(g => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const { lang = 'en' } = Astro.props;

const guide = guides.find(g => g.slug === slug);
if (!guide) {
  return Astro.redirect('/guides/');
}

// Find recommended tools mapping
const recommendedTools = tools.filter(t => guide.relatedTools.includes(t.slug));

// Find related guides mapping
const relatedGuides = guides.filter(g => guide.relatedGuides.includes(g.slug));

// Localize links helper
const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};

// Format FAQ list for Layout.astro standard schema
const faqList = guide.faqs.map(f => ({ q: f.question, a: f.answer }));
---

<Layout 
  title={guide.title} 
  description={guide.description} 
  lang={lang} 
  category="Guides" 
  categorySlug="guides" 
  isTool={true} 
  toolName={guide.h1.replace(/\.$/, '')}
  faqList={faqList}
>
  <style>
    /* Premium Guide Specific Styling conforming to DESIGN.md */
    .guide-main-container {
      max-width: 800px;
      margin: 0 auto;
      padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-5xl);
      position: relative;
      z-index: 1;
    }

    .guide-header {
      margin-bottom: var(--spacing-xl);
      text-align: left;
    }

    .guide-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--colors-mute);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      display: flex;
      gap: var(--spacing-md);
      margin-bottom: var(--spacing-sm);
      align-items: center;
      flex-wrap: wrap;
    }

    .meta-separator {
      color: var(--colors-hairline-strong);
    }

    .guide-title {
      font-size: 38px;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -1.6px;
      color: var(--colors-ink);
      margin: var(--spacing-xs) 0 var(--spacing-sm);
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }

    @media (max-width: 600px) {
      .guide-title {
        font-size: 28px;
        letter-spacing: -1px;
      }
    }

    .guide-intro {
      font-size: 17px;
      color: var(--colors-body);
      line-height: 1.6;
      margin-bottom: var(--spacing-xl);
    }

    /* Core Tool Callout Card */
    .tool-callout-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.02), inset 0px 0px 0px 1px var(--colors-hairline);
      display: flex;
      align-items: center;
      gap: var(--spacing-lg);
      margin: var(--spacing-xl) 0;
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .tool-callout-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0px 8px 30px rgba(0, 0, 0, 0.04), inset 0px 0px 0px 1px var(--colors-hairline-strong);
    }

    @media (max-width: 600px) {
      .tool-callout-card {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--spacing-md);
      }
    }

    .tool-callout-icon {
      font-size: 28px;
      width: 52px;
      height: 52px;
      background-color: var(--colors-canvas-soft-2);
      border-radius: var(--rounded-md);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--colors-hairline);
      flex-shrink: 0;
    }

    .tool-callout-info {
      flex-grow: 1;
    }

    .tool-callout-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--colors-ink);
      margin: 0 0 2px;
    }

    .tool-callout-desc {
      font-size: 13px;
      color: var(--colors-body);
      margin: 0;
      line-height: 1.4;
    }

    .tool-callout-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background-color: var(--colors-primary);
      color: var(--colors-on-primary);
      font-size: 13.5px;
      font-weight: 500;
      padding: var(--spacing-xs) var(--spacing-md);
      border-radius: var(--rounded-pill);
      text-decoration: none;
      transition: background-color 0.2s, transform 0.2s;
      flex-shrink: 0;
    }

    .tool-callout-btn:hover {
      background-color: #000000;
      transform: translateY(-1px);
    }

    /* Guide Rich Text Content Body */
    .guide-body {
      font-size: 15.5px;
      line-height: 1.75;
      color: var(--colors-body);
    }

    .guide-body h2 {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.8px;
      color: var(--colors-ink);
      margin-top: var(--spacing-2xl);
      margin-bottom: var(--spacing-sm);
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }

    .guide-body h3 {
      font-size: 17px;
      font-weight: 600;
      letter-spacing: -0.4px;
      color: var(--colors-ink);
      margin-top: var(--spacing-lg);
      margin-bottom: var(--spacing-xs);
      font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    }

    .guide-body p {
      margin-bottom: var(--spacing-md);
    }

    .guide-body ul, .guide-body ol {
      margin-bottom: var(--spacing-md);
      padding-left: var(--spacing-lg);
    }

    .guide-body li {
      margin-bottom: var(--spacing-xs);
    }

    .guide-body blockquote {
      border-left: 3px solid var(--colors-link);
      padding: var(--spacing-sm) var(--spacing-md);
      margin: var(--spacing-lg) 0;
      background-color: var(--colors-canvas-soft-2);
      border-radius: var(--rounded-sm);
      color: var(--colors-ink);
      font-size: 14.5px;
    }

    .guide-body blockquote strong {
      display: block;
      margin-bottom: 2px;
    }

    .guide-body a {
      color: var(--colors-link);
      text-decoration: underline;
      transition: color 0.15s;
    }

    .guide-body a:hover {
      color: var(--colors-link-deep);
    }

    .guide-body .content-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-xl);
      margin: var(--spacing-xl) 0;
      box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.01);
    }

    /* FAQ accordion integration */
    .faq-section {
      margin-top: var(--spacing-4xl);
      border-top: 1px solid var(--colors-hairline);
      padding-top: var(--spacing-3xl);
    }

    .faq-title {
      font-size: 24px;
      font-weight: 600;
      letter-spacing: -0.8px;
      color: var(--colors-ink);
      margin-bottom: var(--spacing-lg);
    }

    .faq-container {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .faq-item {
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      background-color: var(--colors-canvas);
      overflow: hidden;
    }

    .faq-question {
      padding: var(--spacing-md) var(--spacing-lg);
      font-weight: 600;
      font-size: 15px;
      color: var(--colors-ink);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      transition: background-color 0.2s;
    }

    .faq-question:hover {
      background-color: var(--colors-canvas-soft-2);
    }

    .faq-icon {
      transition: transform 0.3s ease;
      color: var(--colors-mute);
    }

    .faq-item.active .faq-icon {
      transform: rotate(45deg);
      color: var(--colors-link);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s ease;
      padding: 0 var(--spacing-lg);
      color: var(--colors-body);
      font-size: 14px;
      line-height: 1.6;
      border-top: 0 solid var(--colors-hairline);
    }

    .faq-item.active .faq-answer {
      padding: var(--spacing-md) var(--spacing-lg);
      border-top-width: 1px;
    }

    /* Related Guides section */
    .related-guides-section {
      margin-top: var(--spacing-5xl);
      border-top: 1px solid var(--colors-hairline);
      padding-top: var(--spacing-3xl);
    }

    .related-guides-title {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.8px;
      color: var(--colors-ink);
      margin-bottom: var(--spacing-xl);
      text-align: center;
    }

    .related-guides-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-lg);
    }

    @media (max-width: 768px) {
      .related-guides-grid {
        grid-template-columns: 1fr;
      }
    }

    .related-guide-card {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-lg);
      padding: var(--spacing-lg);
      text-decoration: none;
      color: var(--colors-ink);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.01);
    }

    .related-guide-card:hover {
      transform: translateY(-2px);
      border-color: var(--colors-hairline-strong);
      box-shadow: 0px 8px 24px rgba(0, 0, 0, 0.03);
    }

    .related-guide-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: var(--colors-link);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }

    .related-guide-name {
      font-size: 16px;
      font-weight: 600;
      line-height: 1.3;
      margin: 0;
    }

    .related-guide-desc {
      font-size: 13px;
      color: var(--colors-body);
      line-height: 1.5;
      margin: 0;
    }

    .related-guide-action {
      font-size: 12.5px;
      font-weight: 500;
      color: var(--colors-link);
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: auto;
      padding-top: var(--spacing-xs);
    }
  </style>

  <main class="guide-main-container">
    <!-- Guide Header Section -->
    <article class="guide-header">
      <div class="guide-meta">
        <span>Published: {guide.publishDate}</span>
        <span class="meta-separator">•</span>
        <span>{guide.readTime}</span>
        <span class="meta-separator">•</span>
        <span>Resources</span>
      </div>
      <h1 class="guide-title">{guide.h1}</h1>
      <p class="guide-intro">{guide.intro}</p>
    </article>

    <!-- Relevant ConvertOcean Tool Recommendation Card -->
    {recommendedTools.map(tool => (
      <div class="tool-callout-card">
        <div class="tool-callout-icon">
          <CategoryIcon icon={tool.icon} width="24" height="24" />
        </div>
        <div class="tool-callout-info">
          <h3 class="tool-callout-title">Secure client-side {tool.name} tool.</h3>
          <p class="tool-callout-desc">{tool.description}</p>
        </div>
        <a href={relLink(`/${tool.slug}/`)} class="tool-callout-btn">
          Open Tool
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    ))}

    <!-- Guide Content Section -->
    <section class="guide-body" set:html={guide.contentHtml} />

    <!-- FAQ Accordion section -->
    {guide.faqs && guide.faqs.length > 0 && (
      <section class="faq-section">
        <h2 class="faq-title">Frequently Asked Questions.</h2>
        <div class="faq-container">
          {guide.faqs.map(faq => (
            <div class="faq-item">
              <div class="faq-question">
                {faq.question}
                <svg class="faq-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </div>
              <div class="faq-answer">
                {faq.answer}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Related Guides section -->
    {relatedGuides.length > 0 && (
      <section class="related-guides-section">
        <h2 class="related-guides-title">Related resources & guides.</h2>
        <div class="related-guides-grid">
          {relatedGuides.map(rg => (
            <a href={relLink(`/guides/${rg.slug}/`)} class="related-guide-card">
              <span class="related-guide-tag">Guide</span>
              <h3 class="related-guide-name">{rg.title.split(' - ')[0]}</h3>
              <p class="related-guide-desc">{rg.description.substring(0, 100)}...</p>
              <span class="related-guide-action">
                Read Guide
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <script is:inline>
    // FAQ Accordion Toggle Interaction
    document.addEventListener('DOMContentLoaded', () => {
      const faqQuestions = document.querySelectorAll('.faq-question');
      faqQuestions.forEach(question => {
        question.addEventListener('click', () => {
          const item = question.parentElement;
          const isActive = item.classList.contains('active');
          
          // Close all FAQ items
          document.querySelectorAll('.faq-item').forEach(i => {
            i.classList.remove('active');
            const answer = i.querySelector('.faq-answer');
            if (answer) answer.style.maxHeight = null;
          });
          
          // Toggle active on click
          if (!isActive) {
            item.classList.add('active');
            const answer = item.querySelector('.faq-answer');
            if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
          }
        });
      });
    });
  </script>
</Layout>
