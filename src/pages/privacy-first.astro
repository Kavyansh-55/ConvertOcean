---
import Layout from '../layouts/Layout.astro';

const { lang = 'en' } = Astro.props;

const title = "Privacy First Guarantee & Data Safety | ConvertOcean";
const description = "Learn how ConvertOcean ensures your private files never touch a remote server through 100% client-side web technology.";

const faqList = [
  {
    q: "How does ConvertOcean convert files without uploading them?",
    a: "ConvertOcean uses WebAssembly (WASM) and local JavaScript compilers to convert files directly inside your browser window. When you load a tool page, all required code is loaded into your browser tab cache, allowing your device's CPU/GPU to parse, compile, and format files locally. Since your file data remains inside sandboxed tab memory, it is never transmitted over the internet or uploaded to a remote server."
  },
  {
    q: "Is my confidential business or financial data safe when converting files?",
    a: "Yes, converting sensitive files on ConvertOcean is completely safe. Because all data processing happens locally on your device (client-side), confidential documents, financial statements, internal spreadsheet formulas, and tax details are never uploaded to any remote server or third-party database. You retain full data sovereignty at all times."
  },
  {
    q: "Can a client-side file converter run without an active internet connection?",
    a: "Yes, ConvertOcean is offline-capable. Once you load the tool page in your web browser, all formatting engines, scripts, and WebAssembly converters are stored in your browser tab cache. You can disconnect your device from the internet entirely and convert files locally with 100% functionality and speed."
  },
  {
    q: "Are files stored temporarily on your servers or cookies?",
    a: "No. ConvertOcean does not utilize remote servers for file processing or data storage. All file contents and parsed values reside temporarily in sandboxed browser memory. Once you download the converted file or close the web browser tab, all temporary data is instantly and permanently purged from your device's RAM."
  },
  {
    q: "Does ConvertOcean collect any user telemetry or conversion metadata?",
    a: "No. ConvertOcean does not track user activities, store analytics telemetry, use tracking cookies, or collect file metadata (such as names, sizes, or paths). Our tools are strictly client-side static assets, ensuring complete user privacy and anonymity without email logins or server logs."
  },
  {
    q: "Why do some files fail to convert inside a browser sandbox?",
    a: "Client-side conversions run entirely within your browser tab's RAM and CPU limitations. If a file has complex parsing structures, corrupted metadata formats, or exceeds tab memory allocations, the sandboxed process may terminate. Ensuring clean file layouts and converting extremely large datasets in smaller chunks typically resolves these local sandbox constraints."
  }
];
---

<Layout title={title} description={description} lang={lang} category="Privacy First" categorySlug="privacy-first" faqList={faqList}>
  <style>
    /* Privacy explanation specific CSS */
    .privacy-container {
      max-width: 800px;
      margin: 0 auto;
    }
    .privacy-lead {
      font-size: 20px;
      color: var(--colors-body);
      line-height: 1.6;
      margin-bottom: var(--spacing-xl);
    }
    .privacy-section-block {
      margin-bottom: var(--spacing-2xl);
    }
    .privacy-section-title {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.6px;
      margin-bottom: var(--spacing-sm);
      color: var(--colors-ink);
    }
    .privacy-text {
      font-size: 15.5px;
      color: var(--colors-body);
      line-height: 1.7;
      margin-bottom: var(--spacing-md);
    }
    .privacy-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-lg);
      margin: var(--spacing-xl) 0;
    }
    @media (max-width: 600px) {
      .privacy-grid {
        grid-template-columns: 1fr;
      }
    }
    .privacy-card-info {
      background-color: var(--colors-canvas);
      border: 1px solid var(--colors-hairline);
      border-radius: var(--rounded-md);
      padding: var(--spacing-lg);
    }
    .privacy-card-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--colors-ink);
      margin-bottom: var(--spacing-xs);
      display: flex;
      align-items: center;
      gap: var(--spacing-xxs);
    }
    .privacy-card-text {
      font-size: 13.5px;
      color: var(--colors-body);
      line-height: 1.6;
    }
  </style>

  <main class="app-container" style="max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-4xl); position: relative; z-index: 1;">
    <div class="privacy-container">
      <div class="page-header">
        <h1 class="page-title">Privacy First.</h1>
        <p class="privacy-lead">We believe your private documents and photos belong to you. That is why ConvertOcean processes all your files directly on your device, with zero server uploads.</p>
      </div>

      <div class="privacy-section-block">
        <h2 class="privacy-section-title">How browser processing works</h2>
        <p class="privacy-text">
          Traditional online file converters force you to upload your files to their external servers. Once uploaded, you lose control over who sees your data, how long it is stored, or if it is analyzed.
        </p>
        <p class="privacy-text">
          ConvertOcean uses modern web technologies to process files differently. Instead of sending files to a server, we run the conversion programs directly inside your browser window. Your files stay on your device and never touch our servers.
        </p>
      </div>

      <div class="privacy-grid">
        <div class="privacy-card-info">
          <h3 class="privacy-card-title">📁 Your files stay on your device</h3>
          <p class="privacy-card-text">
            All data parsing, resizing, stitching, and format changes occur entirely on your local CPU. Your network connection is never used to transmit your document content.
          </p>
        </div>
        <div class="privacy-card-info">
          <h3 class="privacy-card-title">🗑️ Automatic data removal</h3>
          <p class="privacy-card-text">
            Files are processed in a temporary, sandboxed region of your browser's tab memory. Your files are automatically removed when you close the tab.
          </p>
        </div>
      </div>

      <div class="privacy-section-block">
        <h2 class="privacy-section-title">Benefits of local processing</h2>
        <p class="privacy-text">
          By processing files client-side, ConvertOcean provides several major advantages:
        </p>
        <ul style="margin-left: 20px; margin-bottom: 20px; line-height: 1.8; color: var(--colors-body);">
          <li><strong>Absolute Security:</strong> Ideal for confidential bank statements, contracts, IDs, or sensitive client billing info.</li>
          <li><strong>Zero Upload Times:</strong> No waiting for large files to upload to a remote server. Conversions start instantly.</li>
          <li><strong>Offline Utility:</strong> Since conversions run locally, many tools continue working without an internet connection.</li>
          <li><strong>No Registration:</strong> No accounts, no email addresses, and no subscriptions. Start converting immediately.</li>
        </ul>
      </div>

      <div class="privacy-section-block">
        <h2 class="privacy-section-title">Plain English Commitment</h2>
        <p class="privacy-text">
          We promise to be open and simple. We do not hide our process behind technical jargon like "Cold Memory Enforcement" or "Purge Protocols." We simply state the facts: your files are processed in local memory, no uploads are performed, and closing the browser tab purges all data.
        </p>
      </div>
    </div>

    <!-- Reusable FAQ Component -->
    <section class="faq-section" style="max-width: 100%; padding: 0; margin-top: var(--spacing-3xl);">
      <h2 class="faq-title" style="font-size: 22px; margin-bottom: var(--spacing-lg); text-align: left;">Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqList.map(faq => (
          <div class="faq-item">
            <div class="faq-question">
              {faq.q}
              <svg class="faq-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </div>
            <div class="faq-answer">
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
