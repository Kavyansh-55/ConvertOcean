---
import ToolPage from '../[tool].astro';
import { tools } from '../../data/tools';

export function getStaticPaths() {
  const locales = [
    'hi', 'es', 'fr', 'de', 'pt', 'it', 'nl', 'ru', 'tr', 'pl', 'uk', 'ar', 'fa', 'ur', 'bn', 'pa', 'ta', 'te', 'mr', 'gu', 'zh', 'ja', 'ko', 'th', 'vi', 'id', 'ms', 'fil'
  ];
  
  const paths = [];
  for (const lang of locales) {
    for (const t of tools) {
      paths.push({ params: { lang, tool: t.slug } });
    }
  }
  return paths;
}

const { lang, tool } = Astro.params;
---

<ToolPage lang={lang} tool={tool} />
