---
import CategoryPage from '../[category].astro';

export function getStaticPaths() {
  const locales = [
    'hi', 'es', 'fr', 'de', 'pt', 'it', 'nl', 'ru', 'tr', 'pl', 'uk', 'ar', 'fa', 'ur', 'bn', 'pa', 'ta', 'te', 'mr', 'gu', 'zh', 'ja', 'ko', 'th', 'vi', 'id', 'ms', 'fil'
  ];
  const categories = ['pdf-tools', 'image-tools', 'document-tools', 'excel-converter', 'ocr-tools', 'business-tools'];
  
  const paths = [];
  for (const lang of locales) {
    for (const category of categories) {
      paths.push({ params: { lang, category } });
    }
  }
  return paths;
}

const { lang, category } = Astro.params;
---

<CategoryPage lang={lang} category={category} />
