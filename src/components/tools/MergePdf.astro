---
import CategoryIcon from '../CategoryIcon.astro';
const { slug, headline, subtitle } = Astro.props;
---

<style is:global>
  .merge-pdf-container .file-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 320px;
    overflow-y: auto;
    padding: 2px;
  }
  .merge-pdf-container .file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background-color: var(--colors-canvas-soft-2);
    border: 1px solid var(--colors-hairline);
    border-left: 3px solid var(--colors-link);
    border-radius: var(--rounded-md);
    font-size: 13.5px;
    transition: transform 0.2s ease, border-color 0.2s, background-color 0.2s;
  }
  .merge-pdf-container .file-item:hover {
    background-color: var(--colors-canvas);
    border-color: var(--colors-hairline-strong);
    transform: translateX(2px);
  }
  .merge-pdf-container .file-item-name {
    font-weight: 500;
    color: var(--colors-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 320px;
  }
  .merge-pdf-container .file-item-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--colors-mute);
  }
</style>

<script is:inline src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

<div class="page-header">
  <h1 class="page-title">{headline}</h1>
  <p class="page-description">{subtitle}</p>
</div>

<!-- Error Banner -->
<div id="errorBanner" class="error-banner">
  <span>⚠️</span>
  <span id="errorMessage"></span>
</div>

<!-- Progress Indicator -->
<div id="progressOverlay" class="progress-overlay">
  <div class="progress-bar-container">
    <div id="progressBarFill" class="progress-bar-fill"></div>
  </div>
  <div id="progressLabel" class="progress-label">Processing files…</div>
</div>

<div class="workspace-layout merge-pdf-container">
  <!-- Upload & Arrange List Panel -->
  <div class="panel-card">
    <h3 class="panel-section-title">Upload & Arrange PDFs</h3>
    
    <div id="dropZone" class="upload-card" onclick="document.getElementById('fileInput').click()">
      <div class="upload-icon"><CategoryIcon icon="🥞" width="40" height="40" /></div>
      <div class="upload-text-primary">Drag and drop files here, or click to browse</div>
      <div class="upload-text-secondary">Upload PDF files (Max 25MB each, multiple allowed)</div>
      <input type="file" id="fileInput" class="file-input" accept=".pdf" multiple />
    </div>

    <div id="fileItemsList" class="file-list" style="display: none; margin-top: var(--spacing-md);"></div>
  </div>

  <!-- Settings & Merge Panel -->
  <div class="panel-card">
    <h3 class="panel-section-title">Merge Configuration</h3>
    
    <div class="form-group">
      <label class="form-label" for="mergeOutputName">Output Filename</label>
      <input type="text" id="mergeOutputName" class="form-input" value="merged_document.pdf" />
    </div>

    <div class="button-group" style="margin-top: auto; display: flex; gap: var(--spacing-sm);">
      <button class="button button-primary" id="btnMerge" disabled style="flex: 1;">Merge & Download</button>
      <button class="button button-danger" id="btnClear" disabled>Clear Queue</button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const errorBanner = document.getElementById('errorBanner');
    const errorMessage = document.getElementById('errorMessage');
    const progressOverlay = document.getElementById('progressOverlay');
    const progressBarFill = document.getElementById('progressBarFill');
    const progressLabel = document.getElementById('progressLabel');
    const fileItemsList = document.getElementById('fileItemsList');
    const mergeOutputName = document.getElementById('mergeOutputName');
    const btnMerge = document.getElementById('btnMerge');
    const btnClear = document.getElementById('btnClear');

    let mergeFiles = [];

    // Drag and drop setup
    ['dragenter', 'dragover'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropZone.classList.add('dragover');
      }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropZone.classList.remove('dragover');
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      let files = Array.from(e.dataTransfer.files);
      if (files.length > 0) processFiles(files);
    });

    fileInput.addEventListener('change', (e) => {
      let files = Array.from(e.target.files);
      if (files.length > 0) processFiles(files);
    });

    function showProgress(pct, label) {
      progressOverlay.style.display = 'flex';
      progressBarFill.style.width = pct + '%';
      progressLabel.textContent = label;
    }

    // Fix helper since downloadBlob was missing in some layout scopes
    window.downloadBlob = window.downloadBlob || function(blob, name) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = name;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    };

    function hideProgress() {
      progressOverlay.style.display = 'none';
    }

    function showError(msg) {
      errorMessage.textContent = msg;
      errorBanner.style.display = 'flex';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function hideError() {
      errorBanner.style.display = 'none';
    }

    function processFiles(files) {
      hideError();
      let processed = 0;
      showProgress(10, "Loading PDF documents…");

      files.forEach(f => {
        const reader = new FileReader();
        reader.onload = async function(e) {
          try {
            const bytes = new Uint8Array(e.target.result);
            const doc = await PDFLib.PDFDocument.load(bytes);
            mergeFiles.push({
              name: f.name,
              bytes: bytes,
              pages: doc.getPageCount()
            });
            processed++;

            if (processed === files.length) {
              fileInput.value = ''; // reset so same file can be re-added
              renderList();
              hideProgress();
            }
          } catch(err) {
            processed++;
            showError("Failed to parse " + f.name + ". Please make sure it is a valid PDF.");
            hideProgress();
          }
        };
        reader.readAsArrayBuffer(f);
      });
    }

    function renderList() {
      if (mergeFiles.length === 0) {
        fileItemsList.innerHTML = '';
        fileItemsList.style.display = 'none';
        btnMerge.disabled = true;
        btnClear.disabled = true;
        return;
      }

      fileItemsList.innerHTML = '';
      mergeFiles.forEach((file, index) => {
        const div = document.createElement('div');
        div.className = 'file-item';
        div.innerHTML = `
          <div class="file-item-name">${file.name}</div>
          <div style="display: flex; align-items: center; gap: var(--spacing-sm);">
            <span class="file-item-meta">${file.pages} pgs</span>
            <button class="icon-btn danger" style="background: none; border: none; cursor: pointer; color: var(--colors-mute); font-size: 14px; transition: color 0.2s;" onmouseover="this.style.color='var(--colors-error)'" onmouseout="this.style.color='var(--colors-mute)'" onclick="window.removeMergeFile(${index})">✕</button>
          </div>
        `;
        fileItemsList.appendChild(div);
      });
      fileItemsList.style.display = 'flex';
      btnMerge.disabled = false;
      btnClear.disabled = false;
    }

    window.removeMergeFile = function(idx) {
      mergeFiles.splice(idx, 1);
      renderList();
    };

    btnMerge.addEventListener('click', async () => {
      if (mergeFiles.length < 2) {
        showError("Please upload at least 2 PDF files.");
        return;
      }
      showProgress(20, "Compiling PDF merging…");
      try {
        const mergedPdf = await PDFLib.PDFDocument.create();
        for (let i = 0; i < mergeFiles.length; i++) {
          const file = mergeFiles[i];
          const doc = await PDFLib.PDFDocument.load(file.bytes);
          const copiedPages = await mergedPdf.copyPages(doc, doc.getPageIndices());
          copiedPages.forEach(page => mergedPdf.addPage(page));
        }
        const mergedBytes = await mergedPdf.save();
        let name = mergeOutputName.value || 'merged.pdf';
        if(!name.endsWith('.pdf')) name += '.pdf';
        window.downloadBlob(new Blob([mergedBytes], { type: "application/pdf" }), name);
      } catch(err) {
        showError("Failed to merge PDF files.");
      }
      hideProgress();
    });

    btnClear.addEventListener('click', resetFile);

    function resetFile() {
      mergeFiles = [];
      renderList();
      fileInput.value = '';
      hideProgress();
      hideError();
    }
  })();
</script>
