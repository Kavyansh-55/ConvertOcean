---
const { slug, headline, subtitle } = Astro.props;
---

<style is:global>
  .merge-pptx-container .file-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    max-height: 300px;
    overflow-y: auto;
  }
  .merge-pptx-container .file-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--colors-canvas-soft);
    border: 1px solid var(--colors-hairline);
    border-radius: 6px;
    font-size: 13px;
  }
  .merge-pptx-container .icon-btn {
    background: none;
    border: 1px solid var(--colors-hairline);
    border-radius: 4px;
    color: var(--colors-body);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 11px;
    transition: all 0.15s;
  }
  .merge-pptx-container .icon-btn:hover:not(:disabled) {
    background-color: var(--colors-canvas-soft-2);
    color: var(--colors-ink);
    border-color: var(--colors-hairline-strong);
  }
  .merge-pptx-container .icon-btn.danger:hover {
    background-color: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<div class="page-header">
  <h1 class="page-title">{headline}</h1>
  <p class="page-description">{subtitle}</p>
</div>

<!-- Error Banner -->
<div id="errorBanner" class="error-banner">
  <span>⚠️</span>
  <span id="errorMessage"></span>
</div>

<!-- Progress Indicator -->
<div id="progressOverlay" class="progress-overlay">
  <div class="progress-bar-container">
    <div id="progressBarFill" class="progress-bar-fill"></div>
  </div>
  <div id="progressLabel" class="progress-label">Processing files…</div>
</div>

<div class="workspace-layout merge-pptx-container">
  <!-- Upload & Arrange List Panel -->
  <div class="panel-card">
    <h3 class="panel-section-title">Upload & Arrange PowerPoint Presentations</h3>
    
    <div id="dropZone" class="upload-card" onclick="document.getElementById('fileInput').click()">
      <div class="upload-icon">📊</div>
      <div class="upload-text-primary">Drag and drop PowerPoint presentations here, or click to browse</div>
      <div class="upload-text-secondary">Upload multiple .pptx presentations (Max 25MB each)</div>
      <input type="file" id="fileInput" class="file-input" accept=".pptx" multiple />
    </div>

    <div id="fileItemsList" class="file-list" style="display: none; margin-top: var(--spacing-md);"></div>
  </div>

  <!-- Settings & Merge Panel -->
  <div class="panel-card">
    <h3 class="panel-section-title">Merge Configuration</h3>
    
    <div class="form-group">
      <label class="form-label" for="mergeOutputName">Output Filename</label>
      <input type="text" id="mergeOutputName" class="form-input" value="merged_presentation.pptx" />
    </div>

    <div class="button-group" style="margin-top: auto; display: flex; gap: var(--spacing-sm);">
      <button class="button button-primary" id="btnMerge" disabled style="flex: 1;">Merge & Download</button>
      <button class="button button-danger" id="btnClear" disabled>Clear Queue</button>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const errorBanner = document.getElementById('errorBanner');
    const errorMessage = document.getElementById('errorMessage');
    const progressOverlay = document.getElementById('progressOverlay');
    const progressBarFill = document.getElementById('progressBarFill');
    const progressLabel = document.getElementById('progressLabel');
    const fileItemsList = document.getElementById('fileItemsList');
    const mergeOutputName = document.getElementById('mergeOutputName');
    const btnMerge = document.getElementById('btnMerge');
    const btnClear = document.getElementById('btnClear');

    let mergeFiles = [];

    // Drag and drop setup
    ['dragenter', 'dragover'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropZone.classList.add('dragover');
      }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropZone.classList.remove('dragover');
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      let files = Array.from(e.dataTransfer.files);
      if (files.length > 0) processFiles(files);
    });

    fileInput.addEventListener('change', (e) => {
      let files = Array.from(e.target.files);
      if (files.length > 0) processFiles(files);
    });

    function showProgress(pct, label) {
      progressOverlay.style.display = 'flex';
      progressBarFill.style.width = pct + '%';
      progressLabel.textContent = label;
    }

    // Fix helper since downloadBlob was missing in some layout scopes
    window.downloadBlob = window.downloadBlob || function(blob, name) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = name;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    };

    function hideProgress() {
      progressOverlay.style.display = 'none';
    }

    function showError(msg) {
      errorMessage.textContent = msg;
      errorBanner.style.display = 'flex';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function hideError() {
      errorBanner.style.display = 'none';
    }

    function processFiles(files) {
      hideError();
      let processed = 0;
      showProgress(10, "Loading presentations…");

      files.forEach(f => {
        const ext = f.name.split('.').pop().toLowerCase();
        if (ext !== 'pptx') {
          showError(`Skipped "${f.name}": Unsupported format. Only .pptx is supported.`);
          processed++;
          if (processed === files.length) hideProgress();
          return;
        }

        const reader = new FileReader();
        reader.onload = async function(e) {
          try {
            const bytes = new Uint8Array(e.target.result);
            const zip = await JSZip.loadAsync(bytes);
            
            // Count slides
            let slidesCount = 0;
            zip.folder("ppt/slides").forEach((path) => {
              if (path.match(/^slide\d+\.xml$/)) slidesCount++;
            });

            mergeFiles.push({
              name: f.name,
              bytes: bytes,
              slides: slidesCount
            });
            processed++;

            if (processed === files.length) {
              fileInput.value = ''; // reset so same file can be re-added
              renderList();
              hideProgress();
            }
          } catch(err) {
            processed++;
            showError("Failed to parse " + f.name);
            hideProgress();
          }
        };
        reader.readAsArrayBuffer(f);
      });
    }

    function renderList() {
      if (mergeFiles.length === 0) {
        fileItemsList.innerHTML = '';
        fileItemsList.style.display = 'none';
        btnMerge.disabled = true;
        btnClear.disabled = true;
        return;
      }

      fileItemsList.innerHTML = '';
      mergeFiles.forEach((file, index) => {
        const div = document.createElement('div');
        div.className = 'file-item';
        div.innerHTML = `
          <span>${file.name} (${file.slides} slides)</span>
          <div style="display: flex; gap: 4px;">
            <button class="icon-btn" onclick="window.moveFile(${index}, -1)" ${index === 0 ? 'disabled' : ''}>▲</button>
            <button class="icon-btn" onclick="window.moveFile(${index}, 1)" ${index === mergeFiles.length - 1 ? 'disabled' : ''}>▼</button>
            <button class="icon-btn danger" onclick="window.removeMergeFile(${index})">✕</button>
          </div>
        `;
        fileItemsList.appendChild(div);
      });
      fileItemsList.style.display = 'flex';
      btnMerge.disabled = false;
      btnClear.disabled = false;
    }

    window.moveFile = function(index, direction) {
      const target = index + direction;
      if (target < 0 || target >= mergeFiles.length) return;
      const temp = mergeFiles[index];
      mergeFiles[index] = mergeFiles[target];
      mergeFiles[target] = temp;
      renderList();
    };

    window.removeMergeFile = function(idx) {
      mergeFiles.splice(idx, 1);
      renderList();
    };

    btnMerge.addEventListener('click', async () => {
      if (mergeFiles.length < 2) {
        showError("Please upload at least 2 PowerPoint presentations.");
        return;
      }
      showProgress(20, "Loading base PowerPoint structure…");
      try {
        // Load presentation 1 as base
        const baseZip = await JSZip.loadAsync(mergeFiles[0].bytes);
        const presXmlText = await baseZip.file("ppt/presentation.xml").async("string");
        const presRelsText = await baseZip.file("ppt/_rels/presentation.xml.rels").async("string");

        const parser = new DOMParser();
        const serializer = new XMLSerializer();

        const presDoc = parser.parseFromString(presXmlText, "text/xml");
        const relsDoc = parser.parseFromString(presRelsText, "text/xml");

        const sldIdLst = presDoc.getElementsByTagName("p:sldIdLst")[0];
        const relationshipsNode = relsDoc.getElementsByTagName("Relationships")[0];

        // Track relationships and slides count to assign unique indices
        let maxSldId = 256;
        Array.from(sldIdLst.getElementsByTagName("p:sldId")).forEach(node => {
          const id = parseInt(node.getAttribute("id"));
          if (id > maxSldId) maxSldId = id;
        });

        let rIdCounter = 1;
        Array.from(relationshipsNode.getElementsByTagName("Relationship")).forEach(node => {
          const rId = node.getAttribute("Id");
          const m = rId.match(/^rId(\d+)$/);
          if (m) {
            const val = parseInt(m[1]);
            if (val > rIdCounter) rIdCounter = val;
          }
        });

        let baseSlideIndex = 1;
        baseZip.folder("ppt/slides").forEach((path) => {
          const m = path.match(/^slide(\d+)\.xml$/);
          if (m) {
            const idx = parseInt(m[1]);
            if (idx > baseSlideIndex) baseSlideIndex = idx;
          }
        });

        // Loop through subsequent presentation packages and copy slide layouts/relationships
        for (let i = 1; i < mergeFiles.length; i++) {
          showProgress(20 + Math.round((i / mergeFiles.length) * 60), `Combining slides from file ${i + 1}…`);
          const zip = await JSZip.loadAsync(mergeFiles[i].bytes);
          
          const pXmlText = await zip.file("ppt/presentation.xml").async("string");
          const pRelsText = await zip.file("ppt/_rels/presentation.xml.rels").async("string");

          const pDoc = parser.parseFromString(pXmlText, "text/xml");
          const pRelsDoc = parser.parseFromString(pRelsText, "text/xml");
          
          const pSldIds = Array.from(pDoc.getElementsByTagName("p:sldId"));
          
          for (let sld of pSldIds) {
            const origRid = sld.getAttribute("r:id") || sld.getAttribute("id") || sld.getAttributeNS("http://schemas.openxmlformats.org/officeDocument/2006/relationships", "id");
            
            // Find target slide filename
            const relationships = Array.from(pRelsDoc.getElementsByTagName('Relationship'));
            const relNode = relationships.find(r => r.getAttribute('Id') === origRid);
            if (!relNode) continue;

            const targetSlidePath = relNode.getAttribute("Target"); // e.g. "slides/slide1.xml"
            const slideFileName = targetSlidePath.split('/').pop(); // e.g. "slide1.xml"
            
            // Read slide contents
            const slideXmlContent = await zip.file(`ppt/slides/${slideFileName}`).async("string");
            
            // Read slide relationship contents if present
            let slideRelsContent = null;
            const relsPath = `ppt/slides/_rels/${slideFileName}.rels`;
            if (zip.file(relsPath)) {
              slideRelsContent = await zip.file(relsPath).async("string");
            }

            // Write to base zip with new slide index
            baseSlideIndex++;
            maxSldId++;
            rIdCounter++;

            const newSlideFileName = `slide${baseSlideIndex}.xml`;
            baseZip.file(`ppt/slides/${newSlideFileName}`, slideXmlContent);
            if (slideRelsContent) {
              baseZip.file(`ppt/slides/_rels/${newSlideFileName}.rels`, slideRelsContent);
            }

            // Add Relationship to base presentation.xml.rels
            const newRid = `rId${rIdCounter}`;
            const newRelNode = relsDoc.createElement("Relationship");
            newRelNode.setAttribute("Id", newRid);
            newRelNode.setAttribute("Type", "http://schemas.openxmlformats.org/officeDocument/2006/relationships/slide");
            newRelNode.setAttribute("Target", `slides/${newSlideFileName}`);
            relationshipsNode.appendChild(newRelNode);

            // Add slide ID entry to presentation.xml
            const newSldIdNode = presDoc.createElement("p:sldId");
            newSldIdNode.setAttribute("id", String(maxSldId));
            newSldIdNode.setAttribute("r:id", newRid);
            sldIdLst.appendChild(newSldIdNode);
          }
        }

        showProgress(85, "Serializing presentation outputs…");
        const finalPresXmlText = serializer.serializeToString(presDoc);
        const finalPresRelsText = serializer.serializeToString(relsDoc);

        baseZip.file("ppt/presentation.xml", finalPresXmlText);
        baseZip.file("ppt/_rels/presentation.xml.rels", finalPresRelsText);

        const outBlob = await baseZip.generateAsync({ type: "blob" });
        let name = mergeOutputName.value || 'merged.pptx';
        if (!name.endsWith('.pptx')) name += '.pptx';

        window.downloadBlob(outBlob, name, "application/vnd.openxmlformats-officedocument.presentationml.presentation");
      } catch(err) {
        showError("Failed to merge PowerPoint presentations. Please verify your presentations are valid .pptx files.");
      }
      hideProgress();
    });

    btnClear.addEventListener('click', resetFile);

    function resetFile() {
      mergeFiles = [];
      renderList();
      fileInput.value = '';
      hideProgress();
      hideError();
    }
  })();
</script>
