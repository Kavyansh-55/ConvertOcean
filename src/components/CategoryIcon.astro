    <line x1="21" y1="4.6" x2="12.4" y2="13.2"/>
    <line x1="6" y1="9" x2="6" y2="15"/>
  </svg>
)}

{/* Inbox / Empty State / Tray */}
{key === '📥' && (
  <svg xmlns="http://www.w3.org/2000/svg" width={width} height={height} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className}>
    <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
    <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
  </svg>
)}

{/* Fallback */}
{!['file-converter', 'pdf-tools', 'image-tools', 'excel-converter', 'business-tools', 'document-tools', 'developer-tools', '📄', '🥞', '🖼️', '📊', '💼', '📝', '⚙️', '🔍', '🧾', '📈', '🔢', '💰', '✂️', '📥'].includes(key) && (
  <svg xmlns="http://www.w3.org/2000/svg" width={width} height={height} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className}>
    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
