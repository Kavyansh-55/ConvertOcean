---
const { lang = 'en', categorySlug = '' } = Astro.props;


const relLink = (target: string) => {
  const cleanTarget = target.startsWith('/') ? target : `/${target}`;
  if (lang === 'en') return cleanTarget;
  return `/${lang}${cleanTarget}`;
};
---

<!-- Header -->
<header class="nav-bar">
  <a href={relLink('/')} class="nav-brand">
    <img src="/fevicon.png" alt="ConvertOcean Logo" class="brand-logo-img" style="width: 42px; height: 42px; object-fit: contain; flex-shrink: 0; transition: transform 0.2s ease;" />
    <span class="brand-text">Convert<span class="brand-text-sub">ocean</span></span>
  </a>
  
  <nav class="nav-links">
    <a href={relLink('/')} class={`nav-link ${(!categorySlug || categorySlug === 'home') ? 'active' : ''}`}>🏠 Home</a>
    <a href={relLink('/file-converter/')} class={`nav-link ${(categorySlug === 'file-converter') ? 'active' : ''}`}>📄 File Converter</a>
    <a href={relLink('/pdf-tools/')} class={`nav-link ${(categorySlug === 'pdf-tools') ? 'active' : ''}`}>📑 PDF, Split & Merge</a>
    <a href={relLink('/image-tools/')} class={`nav-link ${(categorySlug === 'image-tools') ? 'active' : ''}`}>🖼️ Image Tools</a>
    <a href={relLink('/excel-converter/')} class={`nav-link ${(categorySlug === 'excel-converter') ? 'active' : ''}`}>📊 Excel Converter</a>
    <a href={relLink('/business-tools/')} class={`nav-link ${(categorySlug === 'business-tools') ? 'active' : ''}`}>💼 Business Tools</a>
  </nav>


  <div class="nav-right-group">
    <button id="themeToggle" class="theme-toggle-btn" aria-label="Toggle dark mode">
      <svg id="themeToggleIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      </svg>
    </button>
    <button id="mobileMenuBtn" class="mobile-menu-btn" aria-label="Open navigation menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Dropdown Menu -->
<div id="mobileNavMenu" class="mobile-nav-menu">
  <a href={relLink('/')} class={`mobile-nav-link ${(!categorySlug || categorySlug === 'home') ? 'active' : ''}`}>🏠 Home</a>
  <a href={relLink('/file-converter/')} class={`mobile-nav-link ${(categorySlug === 'file-converter') ? 'active' : ''}`}>📄 File Converter</a>
  <a href={relLink('/pdf-tools/')} class={`mobile-nav-link ${(categorySlug === 'pdf-tools') ? 'active' : ''}`}>📑 PDF, Split & Merge</a>
  <a href={relLink('/image-tools/')} class={`mobile-nav-link ${(categorySlug === 'image-tools') ? 'active' : ''}`}>🖼️ Image Tools</a>
  <a href={relLink('/excel-converter/')} class={`mobile-nav-link ${(categorySlug === 'excel-converter') ? 'active' : ''}`}>📊 Excel Converter</a>
  <a href={relLink('/business-tools/')} class={`mobile-nav-link ${(categorySlug === 'business-tools') ? 'active' : ''}`}>💼 Business Tools</a>
</div>
